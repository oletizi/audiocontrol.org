---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Logo from '../components/Logo.astro';

// Topic section (retained, currently hidden). Restore when the
// publication has enough dispatches to back up the topic claims.
// Until then the homepage lists actually-published dispatches in the
// same visual slot; see the "Recent dispatches" section below.
//
// interface Topic {
//   marker: string;
//   name: string;
//   rationale: string;
// }
//
// const topics: Topic[] = [
//   { marker: '§ 01', name: 'Workflow patterns', rationale: '...' },
//   { marker: '§ 02', name: 'Editorial cadence', rationale: '...' },
//   { marker: '§ 03', name: 'Automation that actually ships', rationale: '...' },
//   { marker: '§ 04', name: 'Instrumenting the loop', rationale: '...' },
//   { marker: '§ 05', name: 'Field notes from the desk', rationale: '...' },
// ];

// Currently-published dispatches (newest first). Displayed in the
// "Recent dispatches" homepage section until the topic list above
// has enough backing articles to stand up.
const entries = await getCollection('blog', ({ data }) =>
  import.meta.env.PROD ? data.state === 'published' : true,
);
const recentDispatches = entries
  .map((entry) => ({
    slug: entry.id,
    title: entry.data.title,
    description: entry.data.description,
    datePublished: entry.data.datePublished,
  }))
  .sort((a, b) => b.datePublished.localeCompare(a.datePublished));

function formatDispatchDate(dateStr: string): string {
  return new Date(dateStr + 'T00:00:00').toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

// Today's date, rendered in editorial masthead style.
const today = new Date();
const issueDate = today.toLocaleDateString('en-US', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout
  title="editorialcontrol.org — A publication on building with AI agents"
  description="A publication about building with AI agents: workflow patterns, editorial cadence, and automation that actually ships. A sibling to audiocontrol.org."
>
  {/* Running ticker across the top — publication metadata */}
  <div class="ticker" aria-hidden="true">
    <div class="ticker-track">
      {Array.from({ length: 2 }).map(() => (
        <span>
          <span class="ticker-mark">◆</span>A publication on building with AI agents
          <span class="ticker-mark">◆</span>Vol. 01 / Issue 00 — Pre-press
          <span class="ticker-mark">◆</span>Sibling to audiocontrol.org
          <span class="ticker-mark">◆</span>Published from a terminal
        </span>
      ))}
    </div>
  </div>

  <section class="masthead site-container">
    <div class="masthead-reading">
      <h1 class="mast">
        <Logo variant="masthead" />
      </h1>

      <p class="lede">
        A publication about <em>building with AI agents</em> — workflow patterns, editorial cadence,
        and the automation that actually ships, written by someone who would rather be using
        the work than describing it.
      </p>
    </div>

    <aside class="marginalia masthead-marginalia" aria-label="Issue stamp">
      <p class="marginalia-kicker">Issue</p>
      <p class="marginalia-emph">Vol. 01 / Issue 00</p>
      <p class="marginalia-line">Pre-press</p>
      <time class="marginalia-line tabular" datetime={today.toISOString().slice(0, 10)}>
        {issueDate}
      </time>
    </aside>

    <hr class="rule-masthead" />
  </section>

  {/* Editorial spread — three columns, each a short editorial statement */}
  <section class="spread site-container" aria-labelledby="spread-heading">
    <h2 id="spread-heading" class="sr-only">Editorial spread</h2>

    <article class="column">
      <p class="column-label">What's here</p>
      <p class="column-body dropcap">
        Posts on getting real work done with LLM agents. Not tutorials. Not benchmarks. The
        day-to-day texture of running workflows where the model is a collaborator and the
        human's job is to notice when the work goes sideways.
      </p>
    </article>

    <article class="column">
      <p class="column-label">Why bother</p>
      <p class="column-body dropcap">
        Because the interesting part isn't the model — it's what it does to your process.
        Calendars, review cycles, publishing cadences: all of it shifts when the person at
        the desk can delegate, then correct. That shift deserves a press of its own.
      </p>
    </article>

    <article class="column">
      <p class="column-label">How we publish</p>
      <p class="column-body dropcap">
        Slowly. Every piece here is drafted by an agent and finished by a human, using the
        same editorial calendar you can read about in the posts. Nothing ships that wouldn't
        survive a read-aloud. The receipts stay on the page.
      </p>
    </article>
  </section>

  {/* Recent dispatches — replaces the aspirational "On the desk" topic
      list while the publication builds a back catalog. Same visual slot
      and numbered-marker register; content is actually-published posts
      sorted newest-first. Restore the topic list from the commented
      block at the top of this file once the dispatches can back up
      the sections. */}
  <section class="schedule site-container">
    <div class="schedule-reading">
      <div class="schedule-header">
        <h2 class="schedule-title">Recent dispatches</h2>
        <p class="schedule-note">
          Each issue is slowly published, one dispatch at a time. Below is what's shipped so
          far, newest first.
        </p>
      </div>

      <hr class="rule-single" />

      <ol class="dispatches">
        {recentDispatches.map((d, i) => (
          <li class="dispatch-item">
            <a class="dispatch-link" href={`/blog/${d.slug}/`}>
              <div class="dispatch-meta">
                <span class="dispatch-num tabular">No. {String(i + 1).padStart(2, '0')}</span>
                <time class="dispatch-date tabular" datetime={d.datePublished}>
                  {formatDispatchDate(d.datePublished)}
                </time>
              </div>
              <h3 class="dispatch-title-item">{d.title}</h3>
              <p class="dispatch-description">{d.description}</p>
            </a>
          </li>
        ))}
      </ol>

      <p class="dispatches-footer">
        <a href="/blog/" class="dispatches-more">
          All dispatches on the desk <span class="arrow" aria-hidden="true">→</span>
        </a>
      </p>
    </div>

    <aside class="marginalia schedule-marginalia" aria-label="Desk index">
      <p class="marginalia-kicker">The desk</p>
      <p class="marginalia-emph">
        {recentDispatches.length}{' '}
        {recentDispatches.length === 1 ? 'dispatch' : 'dispatches'} indexed
      </p>
      <p class="marginalia-line marginalia-line--serif">Slowly published.</p>
      <p class="marginalia-line marginalia-line--serif">One issue at a time.</p>
    </aside>
  </section>

  {/* Dispatch / signup — quiet, typographic */}
  <section class="dispatch site-container">
    <hr class="rule-double" />

    <div class="dispatch-grid">
      <div class="dispatch-content">
        <p class="dispatch-kicker">The dispatch</p>
        <p class="dispatch-lede">
          When the first issue ships, it goes out to a short list. Want it?
        </p>
        <a class="dispatch-cta" href="mailto:orion@editorialcontrol.org?subject=editorialcontrol%20dispatch">
          Write to the editor
          <span class="arrow" aria-hidden="true">→</span>
        </a>
        <p class="dispatch-fineprint">
          No form, no funnel. An email. Reply asks to be added; I reply when the first piece
          is close.
        </p>
      </div>

      <aside class="marginalia dispatch-marginalia" aria-label="Handling">
        <p class="marginalia-kicker">Handling</p>
        <p class="marginalia-line">By hand</p>
        <p class="marginalia-line">No list</p>
        <p class="marginalia-line">No automation</p>
      </aside>
    </div>
  </section>
</Layout>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ---- Masthead ---- */
  .masthead {
    padding-top: 3.5rem;
    padding-bottom: 1rem;

    /* Reading column + marginalia grid — reading-column sections on
     * the homepage share this shape to deliver the editorial "column
     * with margin furniture" rhythm across masthead, schedule, and
     * dispatch-cta. */
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(10rem, 14rem);
    gap: clamp(2rem, 4vw, 4.5rem);
    align-items: start;
  }

  .masthead > .rule-masthead {
    grid-column: 1 / -1;
    margin-top: 3rem;
  }

  .masthead-reading {
    min-width: 0;
  }

  .mast {
    margin: 0 0 1.5rem 0;
  }

  .lede {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.2vw, 1.6rem);
    line-height: 1.4;
    font-weight: 400;
    max-width: 48rem;
    color: hsl(var(--foreground));
    margin: 0;
    /* Prevent one-word orphans on the last line. */
    text-wrap: pretty;
  }

  .lede em {
    font-style: italic;
    color: hsl(var(--primary));
  }

  /* ---- Marginalia ----------------------------------------------------
   *
   * Small right-column blocks that carry real publication ephemera
   * (issue stamp, desk index, handling promise) in the sections that
   * would otherwise read as "text on the left, empty on the right."
   * Shared across .masthead, .schedule, .dispatch.
   *
   * Typographic register mirrors the .kicker / .column-label pattern
   * already established elsewhere: mono tracked uppercase head, then a
   * short stack of monospace value-lines with one emphasis line in
   * primary chartreuse. Left hairline border evokes a column rule.
   */
  .marginalia {
    padding-left: 1.25rem;
    border-left: 1px solid hsl(var(--border));
    font-family: var(--font-mono);
    font-size: 0.78rem;
    line-height: 1.4;
    letter-spacing: 0.02em;
    color: hsl(var(--muted-foreground));
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin: 0;
  }

  .marginalia p,
  .marginalia time {
    margin: 0;
  }

  .marginalia-kicker {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: hsl(var(--primary));
    margin-bottom: 0.3rem !important;
  }

  .marginalia-emph {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: hsl(var(--accent));
    letter-spacing: 0.06em;
  }

  .marginalia-line {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: hsl(var(--muted-foreground));
    letter-spacing: 0.04em;
  }

  .marginalia-line--serif {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.92rem;
    letter-spacing: 0;
    color: hsl(var(--muted-foreground));
  }

  /* Collapse marginalia to below content on narrower widths. The
   * left-rail border becomes a top rule when stacked so the visual
   * separation survives the orientation change. */
  @media (max-width: 820px) {
    .masthead,
    .schedule,
    .dispatch-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .marginalia {
      padding-left: 0;
      padding-top: 1rem;
      border-left: 0;
      border-top: 1px solid hsl(var(--border));
      max-width: 22rem;
    }
  }

  /* ---- Editorial spread ---- */
  .spread {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem;
    padding-top: 2rem;
    padding-bottom: 3rem;
    position: relative;
  }

  /* Column rules — subtle vertical hairlines between spread columns */
  @media (min-width: 900px) {
    .spread .column:not(:last-child) {
      border-right: 1px solid hsl(var(--border));
      padding-right: 2.5rem;
    }
    .spread .column:not(:first-child) {
      padding-left: 0;
    }
  }

  @media (max-width: 899px) {
    .spread {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  .column-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: hsl(var(--primary));
    margin: 0 0 0.75rem 0;
  }

  .column-body {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.6;
    color: hsl(var(--foreground) / 0.92);
  }

  /* ---- Schedule ---- */
  .schedule {
    padding-top: 4rem;
    padding-bottom: 2rem;

    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(10rem, 14rem);
    gap: clamp(2rem, 4vw, 4.5rem);
    align-items: start;
  }

  .schedule-reading {
    min-width: 0;
  }

  .schedule-header {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 2.5rem;
    align-items: baseline;
  }

  @media (max-width: 720px) {
    .schedule-header {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }
  }

  .schedule-title {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1;
    color: hsl(var(--foreground));
    margin: 0;
  }

  .schedule-note {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-style: italic;
    color: hsl(var(--muted-foreground));
    max-width: 36rem;
    margin: 0;
  }

  /* Dispatch listing on the homepage — mirrors the blog-index
   * "Desk" item pattern (`pages/blog/index.astro`) so the
   * publication reads as one register across surfaces: mono
   * number + uppercase mono date in a meta row, Fraunces italic
   * title (primary on hover), muted body description, hairline
   * separator per item. Single-column block layout keeps the
   * homepage section compact versus the heavier desk treatment. */
  .dispatches {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .dispatch-item {
    border-bottom: 1px solid hsl(var(--border));
  }

  .dispatch-link {
    display: block;
    padding: 1.75rem 0;
    text-decoration: none;
    color: inherit;
    border: 0;
    transition: background 0.15s ease;
  }

  .dispatch-link:hover {
    text-decoration: none;
    background: hsl(var(--card-hover) / 0.28);
  }

  .dispatch-link:focus-visible {
    outline: 2px solid hsl(var(--primary));
    outline-offset: 4px;
  }

  .dispatch-meta {
    display: flex;
    align-items: baseline;
    gap: 1.25rem;
    margin-bottom: 0.6rem;
  }

  .dispatch-num {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    color: hsl(var(--primary));
  }

  .dispatch-date {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    color: hsl(var(--muted-foreground));
    text-transform: uppercase;
  }

  .dispatch-title-item {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(1.4rem, 2.4vw, 1.9rem);
    line-height: 1.2;
    color: hsl(var(--foreground));
    margin: 0 0 0.55rem 0;
    max-width: 44rem;
    transition: color 0.15s ease;
  }

  .dispatch-link:hover .dispatch-title-item {
    color: hsl(var(--primary));
  }

  .dispatch-description {
    font-family: var(--font-body);
    font-size: 0.98rem;
    line-height: 1.55;
    color: hsl(var(--muted-foreground));
    max-width: 44rem;
    margin: 0;
  }

  /* Footer pointer to the full desk — keeps the homepage honest
   * when the dispatch count is small (only 2 posts shipped means
   * the listing is thin; the arrow sends readers to /blog/ where
   * future posts will accumulate). */
  .dispatches-footer {
    margin: 1.75rem 0 0 0;
  }

  .dispatches-more {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: hsl(var(--primary));
    text-decoration: none;
    border: 0;
    padding: 0.3rem 0;
  }

  .dispatches-more:hover,
  .dispatches-more:focus-visible {
    text-decoration: none;
    color: hsl(var(--primary));
  }

  .dispatches-more .arrow {
    transition: transform 0.18s ease;
  }

  .dispatches-more:hover .arrow {
    transform: translateX(3px);
  }

  /* ---- Dispatch ---- */
  .dispatch {
    padding-top: 3.5rem;
    padding-bottom: 2rem;
  }

  .dispatch-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(10rem, 14rem);
    gap: clamp(2rem, 4vw, 4.5rem);
    align-items: start;
  }

  .dispatch-content {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    max-width: 36rem;
    min-width: 0;
  }

  .dispatch-kicker {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: hsl(var(--primary));
  }

  .dispatch-lede {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.4rem, 2.2vw, 1.8rem);
    line-height: 1.35;
    color: hsl(var(--foreground));
  }

  .dispatch-cta {
    align-self: flex-start;
    margin-top: 0.25rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: hsl(var(--primary));
    padding: 0.65rem 1rem;
    border: 1px solid hsl(var(--primary) / 0.5);
    transition: background 0.18s ease, border-color 0.18s ease, color 0.18s ease;
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
  }

  .dispatch-cta:hover {
    background: hsl(var(--primary));
    color: hsl(var(--background));
    border-color: hsl(var(--primary));
    text-decoration: none;
  }

  .dispatch-cta .arrow {
    transition: transform 0.18s ease;
  }

  .dispatch-cta:hover .arrow {
    transform: translateX(3px);
  }

  .dispatch-fineprint {
    font-size: 0.85rem;
    color: hsl(var(--muted-foreground));
    font-style: italic;
  }
</style>
