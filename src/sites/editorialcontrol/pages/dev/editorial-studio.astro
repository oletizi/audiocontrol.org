---
export const prerender = false;

import '../../../../shared/editorial-review.css';
import '../../../../shared/editorial-studio.css';
import { existsSync } from 'fs';
import { join } from 'path';
import {
  buildReport,
  readWorkflows,
  type DraftWorkflowItem,
} from '../../../../../scripts/lib/editorial-review/index.js';
import { readCalendar } from '../../../../../scripts/lib/editorial/calendar.js';
import {
  STAGES,
  effectiveContentType,
  hasRepoContent,
  type CalendarEntry,
  type Stage,
} from '../../../../../scripts/lib/editorial/types.js';

if (import.meta.env.PROD) {
  return new Response('Not Found', { status: 404 });
}

const SITE = 'editorialcontrol';

const workflows = readWorkflows(process.cwd()).filter(w => w.site === SITE);
const approved = workflows.filter(w => w.state === 'approved');
const terminal = workflows
  .filter(w => w.state === 'applied' || w.state === 'cancelled')
  .sort((a, b) => b.updatedAt.localeCompare(a.updatedAt))
  .slice(0, 10);

let calendarEntries: CalendarEntry[] = [];
let distributions: ReturnType<typeof readCalendar>['distributions'] = [];
try {
  const cal = readCalendar(process.cwd(), SITE);
  calendarEntries = cal.entries;
  distributions = cal.distributions;
} catch (e) {
  console.error('[editorial-studio] failed to read calendar:', e);
}

// Shortform coverage matrix: which Published entries have shortform copy
// on each platform. Used by the "Short form" panel below Published.
const PLATFORMS_ORDER = ['reddit', 'linkedin', 'youtube', 'instagram'] as const;
type ShortformPlatform = (typeof PLATFORMS_ORDER)[number];
const shortformCoverage = new Map<string, Set<ShortformPlatform>>();
for (const d of distributions) {
  if (!d.shortform) continue;
  if (!(PLATFORMS_ORDER as readonly string[]).includes(d.platform)) continue;
  const set = shortformCoverage.get(d.slug) ?? new Set();
  set.add(d.platform as ShortformPlatform);
  shortformCoverage.set(d.slug, set);
}
// Sort published entries by datePublished descending for the matrix.
const publishedBlogEntries = calendarEntries
  .filter(e => e.stage === 'Published' && effectiveContentType(e) === 'blog')
  .sort((a, b) => (b.datePublished ?? '').localeCompare(a.datePublished ?? ''));

// Index active workflows by slug for fast per-entry lookup.
const activeWorkflowsBySlug = new Map<string, DraftWorkflowItem[]>();
for (const w of workflows) {
  if (w.state === 'applied' || w.state === 'cancelled') continue;
  const list = activeWorkflowsBySlug.get(w.slug) ?? [];
  list.push(w);
  activeWorkflowsBySlug.set(w.slug, list);
}

function longformWorkflow(slug: string): DraftWorkflowItem | undefined {
  return activeWorkflowsBySlug.get(slug)?.find(w => w.contentKind === 'longform');
}

function entryHasFile(entry: CalendarEntry): boolean {
  if (!hasRepoContent(effectiveContentType(entry))) return false;
  const path = join(
    process.cwd(),
    'src', 'sites', SITE, 'pages', 'blog', entry.slug, 'index.md',
  );
  return existsSync(path);
}

// Group entries by stage (preserve stage order).
const entriesByStage = new Map<Stage, CalendarEntry[]>();
for (const stage of STAGES) entriesByStage.set(stage, []);
for (const e of calendarEntries) entriesByStage.get(e.stage)?.push(e);

const report = buildReport(process.cwd(), { site: SITE });
const totalTerminal = report.all.approvedCount + report.all.cancelledCount;
const hasEnoughSignal = totalTerminal >= 5;
const topTwo = report.topCategories.filter(c => c.count > 0).slice(0, 2);

// Press-check masthead metadata.
const volume = '01';
const issueNum = String(workflows.length).padStart(2, '0');
const now = new Date();
const monthNames = [
  'January','February','March','April','May','June',
  'July','August','September','October','November','December',
];
const issueDate = `${now.getDate()} ${monthNames[now.getMonth()]} ${now.getFullYear()}`;

function fmtRelTime(iso: string): string {
  const t = new Date(iso).getTime();
  const s = Math.max(0, Math.floor((Date.now() - t) / 1000));
  if (s < 60) return `${s}s ago`;
  const m = Math.floor(s / 60);
  if (m < 60) return `${m}m ago`;
  const h = Math.floor(m / 60);
  if (h < 48) return `${h}h ago`;
  return `${Math.floor(h / 24)}d ago`;
}

function workflowLink(w: DraftWorkflowItem): string {
  if (w.contentKind === 'shortform') {
    return `/dev/editorial-review-shortform?focus=${w.id}#workflow-${w.id}`;
  }
  return `/dev/editorial-review/${w.slug}`;
}

function stateLabel(state: string): string {
  return state.replace('-', ' ');
}

// Ornament per stage — adds a tiny mark of visual identity.
const STAGE_ORNAMENTS: Record<Stage, string> = {
  Ideas: '◇',
  Planned: '§',
  Drafting: '✎',
  Review: '※',
  Published: '✓',
};
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Editorial Studio — {SITE} — dev</title>
</head>
<body data-review-ui="studio">
  <header class="er-masthead">
    <div class="er-masthead-kicker">
      Vol. {volume} · № {issueNum} · Press-check
    </div>
    <h1 class="er-masthead-title">
      Editorial <em>Studio</em>
    </h1>
    <p class="er-masthead-deck">
      {SITE}.org &nbsp;·&nbsp; backstage of the desk
    </p>
    <div class="er-masthead-meta">
      <span>{issueDate}</span>
      <span class="sep">·</span>
      <span>{calendarEntries.length} on the calendar</span>
      <span class="sep">·</span>
      <span>{activeWorkflowsBySlug.size} in review</span>
      <span class="sep">·</span>
      <span>{approved.length} awaiting press</span>
    </div>
  </header>

  <main class="er-container">
    <section class="er-filter" data-filter-strip>
      <span class="er-filter-label">Find</span>
      <input
        type="search"
        data-filter-input
        placeholder="slug, title…"
        autocomplete="off"
      />

      <span class="er-filter-label" style="margin-left: auto;">Stage</span>
      <div class="er-chips" role="tablist">
        <button class="er-chip" aria-pressed="true" data-stage-chip="all">all</button>
        {STAGES.map(s => (
          <button class="er-chip" data-stage-chip={s}>{s.toLowerCase()}</button>
        ))}
      </div>
    </section>

    <div class="er-layout">
      <div>
        {STAGES.map(stage => {
          const stageEntries = entriesByStage.get(stage) ?? [];
          return (
            <section class="er-section" data-stage-section={stage}>
              <h2 class="er-section-title">
                <span>{stage}</span>
                <span class="ornament">{STAGE_ORNAMENTS[stage]}</span>
                <span class="count">№ {stageEntries.length}</span>
              </h2>

              {stageEntries.length === 0 ? (
                <div class="er-empty" style="padding: 1rem 0.25rem; font-size: 0.95rem;">
                  {stage === 'Ideas' && 'No open ideas. Run /editorial-add to capture one.'}
                  {stage === 'Planned' && 'Nothing planned. /editorial-plan <slug> to promote an idea.'}
                  {stage === 'Drafting' && 'No posts in drafting.'}
                  {stage === 'Review' && 'Nothing in review stage.'}
                  {stage === 'Published' && 'No published posts yet.'}
                </div>
              ) : (
                stageEntries.map((entry, i) => {
                  const kind = effectiveContentType(entry);
                  const hasFile = entryHasFile(entry);
                  const wf = longformWorkflow(entry.slug);
                  const search = [
                    entry.slug,
                    entry.title,
                    (entry.targetKeywords ?? []).join(' '),
                    kind,
                  ].join(' ').toLowerCase();
                  return (
                    <div
                      class="er-calendar-row"
                      data-stage={stage}
                      data-slug={entry.slug}
                      data-search={search}
                    >
                      <span class="er-row-num">№ {String(i + 1).padStart(2, '0')}</span>
                      <div class="er-calendar-body">
                        <span class="er-row-slug">
                          {wf ? (
                            <a href={workflowLink(wf)}>{entry.slug}</a>
                          ) : entry.slug}
                        </span>
                        <span class="er-calendar-title">{entry.title}</span>
                        {entry.targetKeywords && entry.targetKeywords.length > 0 && stage === 'Planned' && (
                          <span class="er-calendar-meta">
                            <em>kw:</em> {entry.targetKeywords.join(', ')}
                          </span>
                        )}
                        {entry.issueNumber && entry.issueNumber > 0 && (
                          <span class="er-calendar-meta">issue #{entry.issueNumber}</span>
                        )}
                        {entry.datePublished && stage === 'Published' && (
                          <span class="er-calendar-meta">{entry.datePublished}</span>
                        )}
                        {kind !== 'blog' && (
                          <span class="er-calendar-meta er-calendar-meta-kind">{kind}</span>
                        )}
                      </div>
                      <span class="er-calendar-status">
                        {hasRepoContent(kind) && (
                          <span
                            class={`er-file-dot er-file-${hasFile ? 'yes' : 'no'}`}
                            title={hasFile ? 'blog file present' : 'no blog file'}
                          >●</span>
                        )}
                        {wf && (
                          <span class={`er-stamp er-stamp-${wf.state}`}>
                            {stateLabel(wf.state)} v{wf.currentVersion}
                          </span>
                        )}
                      </span>
                      <span class="er-calendar-action">
                        {stage === 'Ideas' && (
                          <button
                            class="er-btn er-btn-small er-copy-btn"
                            type="button"
                            data-copy={`/editorial-plan --site ${SITE} ${entry.slug}`}
                            title="copy command"
                          >plan →</button>
                        )}
                        {stage === 'Planned' && !hasFile && (
                          <button
                            class="er-btn er-btn-small er-btn-primary"
                            type="button"
                            data-action="scaffold-draft"
                            data-slug={entry.slug}
                          >scaffold →</button>
                        )}
                        {stage === 'Planned' && hasFile && (
                          <button
                            class="er-btn er-btn-small er-copy-btn"
                            type="button"
                            data-copy={`/editorial-draft --site ${SITE} ${entry.slug}`}
                          >copy /draft</button>
                        )}
                        {(stage === 'Drafting' || stage === 'Review') && !wf && (
                          <button
                            class="er-btn er-btn-small er-copy-btn"
                            type="button"
                            data-copy={`/editorial-draft-review --site ${SITE} ${entry.slug}`}
                          >copy /review</button>
                        )}
                        {(stage === 'Drafting' || stage === 'Review') && (
                          <button
                            class="er-btn er-btn-small er-btn-approve"
                            type="button"
                            data-action="mark-published"
                            data-slug={entry.slug}
                            title="flip to Published + set date"
                          >publish →</button>
                        )}
                        {stage === 'Published' && !wf && (
                          <button
                            class="er-btn er-btn-small er-copy-btn"
                            type="button"
                            data-copy={`/editorial-draft-review --site ${SITE} ${entry.slug}`}
                            title="re-review a published post"
                          >re-review</button>
                        )}
                      </span>
                    </div>
                  );
                })
              )}
            </section>
          );
        })}

        {publishedBlogEntries.length > 0 && (
          <section class="er-section">
            <h2 class="er-section-title">
              <span>Short form · coverage</span>
              <span class="count">{publishedBlogEntries.length} × {PLATFORMS_ORDER.length}</span>
            </h2>
            <table class="er-sf-matrix">
              <thead>
                <tr>
                  <th scope="col" class="er-sf-slug-col">slug</th>
                  {PLATFORMS_ORDER.map(p => (
                    <th scope="col" class={`er-sf-platform er-sf-platform-${p}`}>{p}</th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {publishedBlogEntries.map(entry => {
                  const covered = shortformCoverage.get(entry.slug) ?? new Set();
                  return (
                    <tr>
                      <th scope="row" class="er-sf-slug">{entry.slug}</th>
                      {PLATFORMS_ORDER.map(p => {
                        const has = covered.has(p);
                        return (
                          <td class={`er-sf-cell ${has ? 'er-sf-cell-covered' : 'er-sf-cell-empty'}`}>
                            {has ? (
                              <span class="er-sf-check" title={`${p} copy drafted`}>✓</span>
                            ) : (
                              <button
                                class="er-copy-btn er-sf-draft-btn"
                                type="button"
                                data-copy={`/editorial-shortform-draft --site ${SITE} ${entry.slug} ${p}`}
                                title={`copy /editorial-shortform-draft for ${p}`}
                              >draft</button>
                            )}
                          </td>
                        );
                      })}
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </section>
        )}

        {approved.length > 0 && (
          <section class="er-section">
            <h2 class="er-section-title">
              <span>Awaiting press</span>
              <span class="count">№ {approved.length}</span>
            </h2>
            {approved.map(w => (
              <a class="er-row" href={workflowLink(w)} data-slug={w.slug} data-state={w.state}>
                <span class="er-row-num">→</span>
                <span class="er-row-slug">{w.slug}</span>
                <span class="er-row-kind">
                  {w.contentKind}
                  {w.contentKind === 'shortform' && w.platform && (
                    <span class="er-row-channel"> · {w.platform}{w.channel ? ` · ${w.channel}` : ''}</span>
                  )}
                </span>
                <span class="er-stamp er-stamp-approved">approved</span>
                <span class="er-row-ts">v{w.currentVersion}</span>
                <span class="er-row-hint">
                  Run · <code>
                    /editorial-approve --site {SITE} {w.slug}
                    {w.contentKind === 'shortform' && w.platform ? ` --platform ${w.platform}${w.channel ? ` --channel ${w.channel}` : ''}` : ''}
                  </code>
                </span>
              </a>
            ))}
          </section>
        )}

        {terminal.length > 0 && (
          <section class="er-section">
            <h2 class="er-section-title">
              <span>Recent proofs</span>
              <span class="count">last {terminal.length}</span>
            </h2>
            {terminal.map(w => (
              <div class="er-row" data-state={w.state}>
                <span class="er-row-num">—</span>
                <span class="er-row-slug" style="color: var(--er-ink-soft);">{w.slug}</span>
                <span class="er-row-kind">
                  {w.contentKind}
                  {w.contentKind === 'shortform' && w.platform && (
                    <span class="er-row-channel"> · {w.platform}</span>
                  )}
                </span>
                <span class={`er-stamp er-stamp-${w.state}`}>{w.state}</span>
                <span class="er-row-ts">{fmtRelTime(w.updatedAt)}</span>
              </div>
            ))}
          </section>
        )}
      </div>

      <aside>
        <section class="er-drift">
          <div class="er-drift-label">Voice-drift · signal</div>
          {hasEnoughSignal && topTwo.length > 0 ? (
            <>
              <p class="er-drift-primary">
                <em>{topTwo[0].category}</em>
                <span class="count"> {topTwo[0].count}</span>
              </p>
              {topTwo[1] && (
                <p class="er-drift-secondary" style="margin: 0;">
                  then <em style="color: var(--er-red-pencil);">{topTwo[1].category}</em> · {topTwo[1].count}
                </p>
              )}
              <div style="margin-top: var(--er-space-2); font-family: var(--er-font-mono); font-size: 0.68rem; color: var(--er-faded); letter-spacing: 0.05em;">
                from {report.all.approvedCount} approved · {report.all.cancelledCount} cancelled<br />
                <code style="margin-top: 0.25rem; display: inline-block;">/editorial-review-report --site {SITE}</code>
              </div>
            </>
          ) : (
            <p style="font-family: var(--er-font-display); font-style: italic; color: var(--er-ink-soft); margin: 0; font-variation-settings: 'opsz' 24, 'wght' 400;">
              {totalTerminal === 0
                ? 'No proofs yet. The signal builds with use.'
                : `Only ${totalTerminal} terminal ${totalTerminal === 1 ? 'proof' : 'proofs'} so far — need ${5 - totalTerminal} more.`}
            </p>
          )}
        </section>

        <section class="er-slip" style="margin-top: var(--er-space-4);">
          <div class="er-slip-header">Short form</div>
          <h3 class="er-slip-title">Social copy</h3>
          <p style="font-size: 0.85rem; margin: 0 0 var(--er-space-1); color: var(--er-ink-soft); font-family: var(--er-font-display);">
            Agent-drafted. Run in Claude Code:
          </p>
          <code style="display: block; font-size: 0.72rem; padding: var(--er-space-1) var(--er-space-2); word-break: break-all; background: var(--er-paper-2);">
            /editorial-shortform-draft --site {SITE} &lt;slug&gt; &lt;platform&gt; [channel]
          </code>
          <p style="margin-top: var(--er-space-2); font-family: var(--er-font-display);">
            <a href="/dev/editorial-review-shortform">Go to the shortform desk →</a>
          </p>
        </section>
      </aside>
    </div>
  </main>

  <div class="er-toast" data-toast hidden></div>
  <div class="er-poll-indicator" data-poll>auto-refresh · 10s</div>

  <span data-site-marker hidden id="__site" data-site={SITE}></span>
  <script is:inline>
    document.body.dataset.site = document.getElementById('__site').dataset.site;
  </script>
  <script>
    import '../../../../shared/editorial-studio-client.ts';
  </script>
</body>
</html>
