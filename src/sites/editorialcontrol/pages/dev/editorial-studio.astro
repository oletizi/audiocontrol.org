---
export const prerender = false;

import '../../../../shared/editorial-review.css';
import '../../../../shared/editorial-studio.css';
import { existsSync } from 'fs';
import { join } from 'path';
import {
  buildReport,
  readWorkflows,
  type DraftWorkflowItem,
} from '../../../../../scripts/lib/editorial-review/index.js';
import { readCalendar } from '../../../../../scripts/lib/editorial/calendar.js';
import { bodyState, type BodyState } from '../../../../../scripts/lib/editorial/body-state.js';
import {
  PLATFORMS,
  SITES,
  STAGES,
  effectiveContentType,
  hasRepoContent,
  type CalendarEntry,
  type Platform,
  type Site,
  type Stage,
} from '../../../../../scripts/lib/editorial/types.js';

if (import.meta.env.PROD) {
  return new Response('Not Found', { status: 404 });
}

// Cross-site studio: read every site's calendar, and index entries by
// their (site, slug) pair. The UI carries a site chip strip so the
// operator can filter; every row and action button carries `data-site`
// so the client knows which calendar to POST against.
interface SitedEntry {
  site: Site;
  entry: CalendarEntry;
}
interface SitedDistribution {
  site: Site;
  platform: string;
  slug: string;
  shortform: boolean;
}

const calendarEntries: SitedEntry[] = [];
const distributions: SitedDistribution[] = [];
for (const site of SITES) {
  try {
    const cal = readCalendar(process.cwd(), site);
    for (const entry of cal.entries) calendarEntries.push({ site, entry });
    for (const d of cal.distributions) {
      distributions.push({ site, platform: d.platform, slug: d.slug, shortform: d.shortform ?? false });
    }
  } catch (e) {
    console.error(`[editorial-studio] failed to read calendar for ${site}:`, e);
  }
}

const workflows = readWorkflows(process.cwd());
const approved = workflows.filter(w => w.state === 'approved');
const terminal = workflows
  .filter(w => w.state === 'applied' || w.state === 'cancelled')
  .sort((a, b) => b.updatedAt.localeCompare(a.updatedAt))
  .slice(0, 10);

// Shortform coverage matrix: which Published entries have shortform copy
// on each platform. Used by the "Short form" panel below Published.
// Display order; source of truth for platform membership is `PLATFORMS`.
const PLATFORMS_ORDER = ['reddit', 'linkedin', 'youtube', 'instagram'] as const satisfies readonly Platform[];
function isPlatform(value: string): value is Platform {
  return (PLATFORMS as readonly string[]).includes(value);
}
// Keyed by `${site}::${slug}` so two sites can legitimately use the same
// slug without their shortform coverage entangling.
const shortformCoverage = new Map<string, Set<Platform>>();
function covKey(site: Site, slug: string): string { return `${site}::${slug}`; }
for (const d of distributions) {
  if (!d.shortform) continue;
  if (!isPlatform(d.platform)) continue;
  const key = covKey(d.site, d.slug);
  const set = shortformCoverage.get(key) ?? new Set<Platform>();
  set.add(d.platform);
  shortformCoverage.set(key, set);
}
// Sort published entries by datePublished descending for the matrix.
const publishedBlogEntries = calendarEntries
  .filter(({ entry }) => entry.stage === 'Published' && effectiveContentType(entry) === 'blog')
  .sort((a, b) => (b.entry.datePublished ?? '').localeCompare(a.entry.datePublished ?? ''));

// Index active workflows by (site, slug) for fast per-entry lookup.
const activeWorkflowsBySitedSlug = new Map<string, DraftWorkflowItem[]>();
for (const w of workflows) {
  if (w.state === 'applied' || w.state === 'cancelled') continue;
  const key = covKey(w.site, w.slug);
  const list = activeWorkflowsBySitedSlug.get(key) ?? [];
  list.push(w);
  activeWorkflowsBySitedSlug.set(key, list);
}

function longformWorkflow(site: Site, slug: string): DraftWorkflowItem | undefined {
  return activeWorkflowsBySitedSlug.get(covKey(site, slug))?.find(w => w.contentKind === 'longform');
}

function outlineWorkflow(site: Site, slug: string): DraftWorkflowItem | undefined {
  return activeWorkflowsBySitedSlug.get(covKey(site, slug))?.find(w => w.contentKind === 'outline');
}

/** Whichever workflow is relevant given the entry's calendar stage. */
function stageWorkflow(site: Site, slug: string, stage: Stage): DraftWorkflowItem | undefined {
  if (stage === 'Outlining') return outlineWorkflow(site, slug);
  return longformWorkflow(site, slug);
}

function entryBodyState(site: Site, entry: CalendarEntry): BodyState {
  if (!hasRepoContent(effectiveContentType(entry))) return 'missing';
  const path = join(
    process.cwd(),
    'src', 'sites', site, 'content', 'blog', `${entry.slug}.md`,
  );
  return bodyState(path);
}

function entryHasFile(site: Site, entry: CalendarEntry): boolean {
  return entryBodyState(site, entry) !== 'missing';
}

// Group entries by stage (preserve stage order). Each entry keeps its site tag.
const entriesByStage = new Map<Stage, SitedEntry[]>();
for (const stage of STAGES) entriesByStage.set(stage, []);
for (const e of calendarEntries) entriesByStage.get(e.entry.stage)?.push(e);

// Voice-drift report: aggregate across all sites. Skip the site filter so
// the signal reflects the whole pipeline; the operator can still run
// /editorial-review-report --site <site> in Claude Code for a per-site view.
const report = buildReport(process.cwd(), {});
const totalTerminal = report.all.approvedCount + report.all.cancelledCount;
const hasEnoughSignal = totalTerminal >= 5;
const topTwo = report.topCategories.filter(c => c.count > 0).slice(0, 2);

// Press-check masthead metadata.
const volume = '01';
const issueNum = String(workflows.length).padStart(2, '0');
const now = new Date();
const monthNames = [
  'January','February','March','April','May','June',
  'July','August','September','October','November','December',
];
const issueDate = `${now.getDate()} ${monthNames[now.getMonth()]} ${now.getFullYear()}`;

function fmtRelTime(iso: string): string {
  const t = new Date(iso).getTime();
  const s = Math.max(0, Math.floor((Date.now() - t) / 1000));
  if (s < 60) return `${s}s ago`;
  const m = Math.floor(s / 60);
  if (m < 60) return `${m}m ago`;
  const h = Math.floor(m / 60);
  if (h < 48) return `${h}h ago`;
  return `${Math.floor(h / 24)}d ago`;
}

function workflowLink(w: DraftWorkflowItem): string {
  if (w.contentKind === 'shortform') {
    return `/dev/editorial-review-shortform?focus=${w.id}#workflow-${w.id}`;
  }
  if (w.contentKind === 'outline') {
    return `/dev/editorial-review/${w.slug}?site=${w.site}&kind=outline`;
  }
  return `/dev/editorial-review/${w.slug}?site=${w.site}`;
}

/**
 * Dev-preview URL for a scaffolded blog article. The studio is
 * served from editorialcontrol's dev server, so same-origin links
 * only work for editorialcontrol articles — audiocontrol has its
 * own dev server (auto-assigned port when both run in parallel),
 * which we can't reliably predict. Return null for cross-site
 * rows; the caller falls back to plain text.
 *
 * In dev, drafts render via the content-collection `[slug].astro`
 * route regardless of `state: draft | published` (17b filters only
 * in prod). So a drafted article is readable at its final URL
 * before approval.
 */
function blogPreviewLink(site: Site, slug: string): string | null {
  if (site === 'editorialcontrol') return `/blog/${slug}/`;
  return null;
}

// Short, mono site label shown on each row and card.
function siteLabel(site: Site): string {
  return site === 'audiocontrol' ? 'AC' : 'EC';
}

function stateLabel(state: string): string {
  return state.replace('-', ' ');
}

// Ornament per stage — adds a tiny mark of visual identity.
const STAGE_ORNAMENTS: Record<Stage, string> = {
  Ideas: '◇',
  Planned: '§',
  Outlining: '⊹',
  Drafting: '✎',
  Review: '※',
  Published: '✓',
};
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Editorial Studio — all sites — dev</title>
</head>
<body data-review-ui="studio">
  <header class="er-masthead">
    <div class="er-masthead-kicker">
      Vol. {volume} · № {issueNum} · Press-check
    </div>
    <h1 class="er-masthead-title">
      Editorial <em>Studio</em>
    </h1>
    <p class="er-masthead-deck">
      Both sites &nbsp;·&nbsp; backstage of the desk &nbsp;·&nbsp; <a href="/dev/editorial-help" style="color: var(--er-red-pencil);">the manual</a> &nbsp;·&nbsp; <a href="/dev/" style="color: var(--er-red-pencil);">← /dev</a>
    </p>
    <div class="er-masthead-meta">
      <span>{issueDate}</span>
      <span class="sep">·</span>
      <span>{calendarEntries.length} on the calendar</span>
      <span class="sep">·</span>
      <span>{activeWorkflowsBySitedSlug.size} in review</span>
      <span class="sep">·</span>
      <span>{approved.length} awaiting press</span>
    </div>
  </header>

  <main class="er-container">
    <section class="er-filter" data-filter-strip>
      <span class="er-filter-label">Find</span>
      <input
        type="search"
        data-filter-input
        placeholder="slug, title…"
        autocomplete="off"
      />

      <span class="er-filter-label" style="margin-left: 1rem;">Site</span>
      <div class="er-chips" role="tablist">
        <button class="er-chip" aria-pressed="true" data-site-chip="all">all</button>
        {SITES.map(s => (
          <button class="er-chip" data-site-chip={s}>{siteLabel(s).toLowerCase()}</button>
        ))}
      </div>

      <span class="er-filter-label" style="margin-left: 1rem;">Stage</span>
      <div class="er-chips" role="tablist">
        <button class="er-chip" aria-pressed="true" data-stage-chip="all">all</button>
        {STAGES.map(s => (
          <button class="er-chip" data-stage-chip={s}>{s.toLowerCase()}</button>
        ))}
      </div>
    </section>

    <div class="er-layout">
      <div>
        {STAGES.map(stage => {
          const stageEntries = entriesByStage.get(stage) ?? [];
          return (
            <section class="er-section" data-stage-section={stage}>
              <h2 class="er-section-title">
                <span>{stage}</span>
                <span class="ornament">{STAGE_ORNAMENTS[stage]}</span>
                <span class="count">№ {stageEntries.length}</span>
              </h2>

              {stageEntries.length === 0 ? (
                <div class="er-empty" style="padding: 1rem 0.25rem; font-size: 0.95rem;">
                  {stage === 'Ideas' && 'No open ideas. Run /editorial-add to capture one.'}
                  {stage === 'Planned' && 'Nothing planned. /editorial-plan <slug> to promote an idea.'}
                  {stage === 'Outlining' && 'Nothing in outlining. /editorial-outline <slug> to start one.'}
                  {stage === 'Drafting' && 'No posts in drafting.'}
                  {stage === 'Review' && 'Nothing in review stage.'}
                  {stage === 'Published' && 'No published posts yet.'}
                </div>
              ) : (
                stageEntries.map(({ site, entry }, i) => {
                  const kind = effectiveContentType(entry);
                  const body = entryBodyState(site, entry);
                  const hasFile = body !== 'missing';
                  const bodyWritten = body === 'written';
                  const wf = stageWorkflow(site, entry.slug, stage);
                  const search = [
                    entry.slug,
                    entry.title,
                    (entry.targetKeywords ?? []).join(' '),
                    kind,
                    site,
                  ].join(' ').toLowerCase();
                  return (
                    <div
                      class="er-calendar-row"
                      data-stage={stage}
                      data-site={site}
                      data-slug={entry.slug}
                      data-search={search}
                    >
                      <span class="er-row-num">№ {String(i + 1).padStart(2, '0')}</span>
                      <div class="er-calendar-body">
                        <span class={`er-row-site er-row-site--${site}`} title={`${site}.org`}>{siteLabel(site)}</span>
                        <span class="er-row-slug">
                          {wf ? (
                            <a href={workflowLink(wf)} title="open the review surface">{entry.slug}</a>
                          ) : hasFile ? (
                            (() => {
                              const preview = blogPreviewLink(site, entry.slug);
                              return preview ? (
                                <a href={preview} title="read the drafted article in dev">{entry.slug}</a>
                              ) : entry.slug;
                            })()
                          ) : entry.slug}
                        </span>
                        <span class="er-calendar-title">{entry.title}</span>
                        {entry.targetKeywords && entry.targetKeywords.length > 0 && stage === 'Planned' && (
                          <span class="er-calendar-meta">
                            <em>kw:</em> {entry.targetKeywords.join(', ')}
                          </span>
                        )}
                        {entry.issueNumber && entry.issueNumber > 0 && (
                          <span class="er-calendar-meta">issue #{entry.issueNumber}</span>
                        )}
                        {entry.datePublished && stage === 'Published' && (
                          <span class="er-calendar-meta">{entry.datePublished}</span>
                        )}
                        {kind !== 'blog' && (
                          <span class="er-calendar-meta er-calendar-meta-kind">{kind}</span>
                        )}
                      </div>
                      <span class="er-calendar-status">
                        {hasRepoContent(kind) && (
                          <span
                            class={`er-file-dot er-file-${body}`}
                            title={
                              body === 'missing' ? 'no blog file'
                              : body === 'placeholder' ? 'scaffold present, body is the placeholder'
                              : 'body written'
                            }
                          >●</span>
                        )}
                        {wf && (
                          <span class={`er-stamp er-stamp-${wf.state}`}>
                            {stateLabel(wf.state)} v{wf.currentVersion}
                          </span>
                        )}
                      </span>
                      <span class="er-calendar-action">
                        {stage === 'Ideas' && (
                          <button
                            class="er-btn er-btn-small er-copy-btn"
                            type="button"
                            data-copy={`/editorial-plan --site ${site} ${entry.slug}`}
                            title="copy command"
                          >plan →</button>
                        )}
                        {stage === 'Planned' && !hasFile && (
                          <button
                            class="er-btn er-btn-small er-btn-primary"
                            type="button"
                            data-action="scaffold-draft"
                            data-site={site}
                            data-slug={entry.slug}
                          >scaffold →</button>
                        )}
                        {stage === 'Planned' && hasFile && (
                          <button
                            class="er-btn er-btn-small er-btn-primary er-copy-btn"
                            type="button"
                            data-copy={`/editorial-outline --site ${site} ${entry.slug}`}
                            title="scaffold file exists — copy to sketch the outline in Claude Code"
                          >outline →</button>
                        )}
                        {stage === 'Outlining' && wf && wf.state === 'iterating' && (
                          <button
                            class="er-btn er-btn-small er-btn-primary er-copy-btn"
                            type="button"
                            data-copy={`/editorial-iterate --kind outline --site ${site} ${entry.slug}`}
                            title="operator clicked Iterate — run this to revise the outline in Claude Code"
                          >iterate outline →</button>
                        )}
                        {stage === 'Outlining' && wf && wf.state === 'approved' && (
                          <button
                            class="er-btn er-btn-small er-btn-approve er-copy-btn"
                            type="button"
                            data-copy={`/editorial-outline-approve --site ${site} ${entry.slug}`}
                            title="outline approved — advance to Drafting"
                          >approve outline →</button>
                        )}
                        {stage === 'Outlining' && wf && (wf.state === 'open' || wf.state === 'in-review') && (
                          <a
                            class="er-btn er-btn-small"
                            href={workflowLink(wf)}
                            title="open the review surface to annotate / edit the outline"
                          >review outline →</a>
                        )}
                        {stage === 'Outlining' && !wf && (
                          <button
                            class="er-btn er-btn-small er-btn-primary er-copy-btn"
                            type="button"
                            data-copy={`/editorial-outline --site ${site} ${entry.slug}`}
                            title="no outline workflow found — copy to (re)start one"
                          >outline →</button>
                        )}
                        {(stage === 'Drafting' || stage === 'Review') && !bodyWritten && (
                          <button
                            class="er-btn er-btn-small er-btn-primary er-copy-btn"
                            type="button"
                            data-copy={`/editorial-draft --site ${site} ${entry.slug}`}
                            title="body is still the placeholder — draft it in Claude Code"
                          >draft body →</button>
                        )}
                        {(stage === 'Drafting' || stage === 'Review') && bodyWritten && !wf && (
                          <button
                            class="er-btn er-btn-small er-btn-primary er-copy-btn"
                            type="button"
                            data-copy={`/editorial-draft-review --site ${site} ${entry.slug}`}
                            title="body is drafted — copy this command to enqueue a longform review workflow in Claude Code"
                          >enqueue review →</button>
                        )}
                        {(stage === 'Drafting' || stage === 'Review') && (
                          <button
                            class="er-btn er-btn-small er-btn-approve"
                            type="button"
                            data-action="mark-published"
                            data-site={site}
                            data-slug={entry.slug}
                            title="flip to Published + set date"
                          >publish →</button>
                        )}
                        {stage === 'Published' && !wf && (
                          <button
                            class="er-btn er-btn-small er-copy-btn"
                            type="button"
                            data-copy={`/editorial-draft-review --site ${site} ${entry.slug}`}
                            title="re-review a published post"
                          >re-review</button>
                        )}
                      </span>
                    </div>
                  );
                })
              )}
            </section>
          );
        })}

        {publishedBlogEntries.length > 0 && (
          <section class="er-section">
            <h2 class="er-section-title">
              <span>Short form · coverage</span>
              <span class="count">{publishedBlogEntries.length} × {PLATFORMS_ORDER.length}</span>
            </h2>
            <table class="er-sf-matrix">
              <thead>
                <tr>
                  <th scope="col" class="er-sf-slug-col">slug</th>
                  {PLATFORMS_ORDER.map(p => (
                    <th scope="col" class={`er-sf-platform er-sf-platform-${p}`}>{p}</th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {publishedBlogEntries.map(({ site, entry }) => {
                  const covered = shortformCoverage.get(covKey(site, entry.slug)) ?? new Set();
                  return (
                    <tr data-site={site}>
                      <th scope="row" class="er-sf-slug">
                        <span class={`er-row-site er-row-site--${site}`} title={`${site}.org`}>{siteLabel(site)}</span>
                        {entry.slug}
                      </th>
                      {PLATFORMS_ORDER.map(p => {
                        const has = covered.has(p);
                        return (
                          <td class={`er-sf-cell ${has ? 'er-sf-cell-covered' : 'er-sf-cell-empty'}`}>
                            {has ? (
                              <span class="er-sf-check" title={`${p} copy drafted`}>✓</span>
                            ) : (
                              <button
                                class="er-copy-btn er-sf-draft-btn"
                                type="button"
                                data-copy={`/editorial-shortform-draft --site ${site} ${entry.slug} ${p}`}
                                title={`copy /editorial-shortform-draft for ${p}`}
                              >draft</button>
                            )}
                          </td>
                        );
                      })}
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </section>
        )}

        {approved.length > 0 && (
          <section class="er-section">
            <h2 class="er-section-title">
              <span>Awaiting press</span>
              <span class="count">№ {approved.length}</span>
            </h2>
            {approved.map(w => (
              <a class="er-row" href={workflowLink(w)} data-slug={w.slug} data-site={w.site} data-state={w.state}>
                <span class="er-row-num">→</span>
                <span class={`er-row-site er-row-site--${w.site}`} title={`${w.site}.org`}>{siteLabel(w.site)}</span>
                <span class="er-row-slug">{w.slug}</span>
                <span class="er-row-kind">
                  {w.contentKind}
                  {w.contentKind === 'shortform' && w.platform && (
                    <span class="er-row-channel"> · {w.platform}{w.channel ? ` · ${w.channel}` : ''}</span>
                  )}
                </span>
                <span class="er-stamp er-stamp-approved">approved</span>
                <span class="er-row-ts">v{w.currentVersion}</span>
                <span class="er-row-hint">
                  Run · <code>
                    /editorial-approve --site {w.site} {w.slug}
                    {w.contentKind === 'shortform' && w.platform ? ` --platform ${w.platform}${w.channel ? ` --channel ${w.channel}` : ''}` : ''}
                  </code>
                </span>
              </a>
            ))}
          </section>
        )}

        {terminal.length > 0 && (
          <section class="er-section">
            <h2 class="er-section-title">
              <span>Recent proofs</span>
              <span class="count">last {terminal.length}</span>
            </h2>
            {terminal.map(w => (
              <div class="er-row" data-state={w.state} data-site={w.site}>
                <span class="er-row-num">—</span>
                <span class={`er-row-site er-row-site--${w.site}`} title={`${w.site}.org`}>{siteLabel(w.site)}</span>
                <span class="er-row-slug" style="color: var(--er-ink-soft);">{w.slug}</span>
                <span class="er-row-kind">
                  {w.contentKind}
                  {w.contentKind === 'shortform' && w.platform && (
                    <span class="er-row-channel"> · {w.platform}</span>
                  )}
                </span>
                <span class={`er-stamp er-stamp-${w.state}`}>{w.state}</span>
                <span class="er-row-ts">{fmtRelTime(w.updatedAt)}</span>
              </div>
            ))}
          </section>
        )}
      </div>

      <aside>
        <section class="er-drift">
          <div class="er-drift-label">Voice-drift · signal</div>
          {hasEnoughSignal && topTwo.length > 0 ? (
            <>
              <p class="er-drift-primary">
                <em>{topTwo[0].category}</em>
                <span class="count"> {topTwo[0].count}</span>
              </p>
              {topTwo[1] && (
                <p class="er-drift-secondary" style="margin: 0;">
                  then <em style="color: var(--er-red-pencil);">{topTwo[1].category}</em> · {topTwo[1].count}
                </p>
              )}
              <div style="margin-top: var(--er-space-2); font-family: var(--er-font-mono); font-size: 0.68rem; color: var(--er-faded); letter-spacing: 0.05em;">
                from {report.all.approvedCount} approved · {report.all.cancelledCount} cancelled<br />
                <code style="margin-top: 0.25rem; display: inline-block;">/editorial-review-report --site &lt;site&gt;</code>
              </div>
            </>
          ) : (
            <p style="font-family: var(--er-font-display); font-style: italic; color: var(--er-ink-soft); margin: 0; font-variation-settings: 'opsz' 24, 'wght' 400;">
              {totalTerminal === 0
                ? 'No proofs yet. The signal builds with use.'
                : `Only ${totalTerminal} terminal ${totalTerminal === 1 ? 'proof' : 'proofs'} so far — need ${5 - totalTerminal} more.`}
            </p>
          )}
        </section>

        <section class="er-slip" style="margin-top: var(--er-space-4);">
          <div class="er-slip-header">Short form</div>
          <h3 class="er-slip-title">Social copy</h3>
          <p style="font-size: 0.85rem; margin: 0 0 var(--er-space-1); color: var(--er-ink-soft); font-family: var(--er-font-display);">
            Agent-drafted. Run in Claude Code:
          </p>
          <code style="display: block; font-size: 0.72rem; padding: var(--er-space-1) var(--er-space-2); word-break: break-all; background: var(--er-paper-2);">
            /editorial-shortform-draft --site &lt;site&gt; &lt;slug&gt; &lt;platform&gt; [channel]
          </code>
          <p style="margin-top: var(--er-space-2); font-family: var(--er-font-display);">
            <a href="/dev/editorial-review-shortform">Go to the shortform desk →</a>
          </p>
        </section>
      </aside>
    </div>
  </main>

