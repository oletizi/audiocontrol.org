---
export const prerender = false;

import { readFileSync } from 'node:fs';
import { join } from 'node:path';
import OGPreview, {
  type PresetName,
  type FilterState,
  type Site,
  type OverlayPosition,
  type OverlayAlign,
  isOverlayPosition,
  isOverlayAlign,
} from '../../../../components/dev/OGPreview.astro';
import { readLog } from '../../../../../scripts/feature-image/log.js';
import '../../styles/og-preview.css';

if (import.meta.env.PROD) {
  return new Response('Not Found', { status: 404 });
}

const url = Astro.url;
const p = url.searchParams;

const entryId = p.get('entry');
const rawParam = p.get('raw');
const format = (p.get('format') as 'og' | 'youtube' | 'instagram') || 'og';
const title = p.get('title') ?? '';
const subtitle = p.get('subtitle') ?? '';
const preset = (p.get('preset') as PresetName | null) || undefined;
const overlay = p.get('overlay') !== 'off';
const overlayPositionParam = p.get('overlayPosition');
const overlayPosition: OverlayPosition =
  isOverlayPosition(overlayPositionParam) ? overlayPositionParam : 'bottom';
const overlayAlignParam = p.get('overlayAlign');
const overlayAlign: OverlayAlign =
  isOverlayAlign(overlayAlignParam) ? overlayAlignParam : 'auto';

// Font-size multipliers from the focus-page Title/Subtitle sliders.
// Clamp defensively to the same 0.6–1.6 range the slider exposes so
// a broken URL param can't produce absurd typography.
function clampScale(raw: string | null): number | null {
  if (!raw) return null;
  const n = parseFloat(raw);
  if (!Number.isFinite(n)) return null;
  return Math.min(1.6, Math.max(0.6, n));
}
const titleScale = clampScale(p.get('titleScale'));
const subtitleScale = clampScale(p.get('subtitleScale'));

const siteParam = p.get('site');
const validSites: Site[] = ['audiocontrol', 'editorialcontrol'];
const site: Site = (siteParam && (validSites as string[]).includes(siteParam))
  ? (siteParam as Site)
  : 'audiocontrol';

const filterKeys = ['grade', 'phosphor', 'vignette', 'scanlines', 'grain'] as const;
const filters: FilterState = {};
for (const k of filterKeys) {
  const v = p.get(k);
  if (v) (filters as Record<string, string>)[k] = v;
}

const dims: Record<string, { w: number; h: number }> = {
  og: { w: 1200, h: 630 },
  youtube: { w: 1280, h: 720 },
  instagram: { w: 1080, h: 1080 },
};
const { w, h } = dims[format] ?? dims.og;

let bgSrc = rawParam ?? '';
let inheritedSite: Site | null = null;
if (!bgSrc && entryId) {
  const entries = await readLog();
  const entry = entries.find(e => e.id === entryId);
  if (!entry) {
    return new Response(`Entry ${entryId} not found in history`, { status: 404 });
  }
  const raw = entry.outputs?.raw?.[0];
  if (!raw) {
    return new Response(`Entry ${entryId} has no raw output`, { status: 404 });
  }
  bgSrc = raw;
  // If the entry has a site and the caller didn't override, inherit it.
  if (!siteParam && entry.site && (validSites as string[]).includes(entry.site)) {
    inheritedSite = entry.site as Site;
  }
}
if (!bgSrc) {
  return new Response('Must provide entry=<id> or raw=<path>', { status: 400 });
}

const effectiveSite: Site = inheritedSite ?? site;

// The bake page is served by audiocontrol's dev server (the gallery's
// host). A bare `/favicon.svg` therefore always resolves to
// audiocontrol's mark even when the target brand is editorialcontrol.
// Read the target site's favicon from disk and inline it as a data
// URI so the logo always matches the effective site, independent of
// which dev server is serving this page.
const faviconPath = join(
  process.cwd(),
  'src', 'sites', effectiveSite, 'public', 'favicon.svg',
);
const faviconSvg = readFileSync(faviconPath, 'utf-8');
const effectiveLogoSrc =
  'data:image/svg+xml;utf8,' + encodeURIComponent(faviconSvg);

// Each site needs its self-hosted fonts plus a Google-Fonts fallback for any
// display face the preview wants that isn't shipped locally (Fraunces for
// editorialcontrol). Local fonts live under /fonts on their own site; for
// editorialcontrol we pull Fraunces from Google Fonts since it's not bundled.
const fontHead = effectiveSite === 'editorialcontrol'
  ? '<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,700&family=Inter:wght@400;700&family=JetBrains+Mono:wght@400;700&display=swap" />'
  : '<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=IBM+Plex+Sans:wght@400;700&display=swap" />';
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Feature Image Bake — {format} · {effectiveSite}</title>
  <Fragment set:html={fontHead} />
  <style set:html={`
    html, body {
      margin: 0;
      padding: 0;
      background: transparent;
      overflow: hidden;
    }
    body {
      width: ${w}px;
      height: ${h}px;
    }
    /* Audiocontrol's Departure Mono is self-hosted; Editorialcontrol uses
     * Fraunces from Google Fonts above. Both sites' body faces (IBM Plex
     * Sans, Inter) come from Google Fonts since the OGPreview runs outside
     * the site's normal font-face declarations. */
    @font-face {
      font-family: 'Departure Mono';
      src: url('/fonts/departure-mono-regular.woff2') format('woff2');
      font-weight: 400;
      font-style: normal;
      font-display: block;
    }
  `}></style>
</head>
<body>
  <OGPreview
    bgSrc={bgSrc}
    title={title}
    subtitle={subtitle}
    format={format}
    preset={preset}
    filters={filters}
    overlay={overlay}
    overlayPosition={overlayPosition}
    overlayAlign={overlayAlign}
    site={effectiveSite}
    logoSrc={effectiveLogoSrc}
    width={w}
    height={h}
    titleScale={titleScale}
    subtitleScale={subtitleScale}
  />
</body>
</html>
