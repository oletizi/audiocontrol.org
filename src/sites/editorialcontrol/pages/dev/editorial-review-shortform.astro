---
export const prerender = false;

import '../../../../shared/editorial-review.css';
import {
  listOpen,
  readVersions,
  type DraftVersion,
  type DraftWorkflowItem,
} from '../../../../../scripts/lib/editorial-review/index.js';

if (import.meta.env.PROD) {
  return new Response('Not Found', { status: 404 });
}

const SITE = 'editorialcontrol';

const open = listOpen(process.cwd(), SITE).filter(
  (w) => w.contentKind === 'shortform',
);

type Card = {
  workflow: DraftWorkflowItem;
  currentVersion: DraftVersion | null;
};

const cards: Card[] = open.map((w) => {
  const versions = readVersions(process.cwd(), w.id);
  const currentVersion = versions.find((v) => v.version === w.currentVersion) ?? null;
  return { workflow: w, currentVersion };
});

cards.sort((a, b) => b.workflow.updatedAt.localeCompare(a.workflow.updatedAt));

const PLATFORM_ORDER = ['reddit', 'linkedin', 'youtube', 'instagram'] as const;
const byPlatform = new Map<string, Card[]>();
for (const card of cards) {
  const key = card.workflow.platform ?? 'other';
  const list = byPlatform.get(key) ?? [];
  list.push(card);
  byPlatform.set(key, list);
}
const orderedPlatforms = [
  ...PLATFORM_ORDER.filter(p => byPlatform.has(p)),
  ...[...byPlatform.keys()].filter(p => !(PLATFORM_ORDER as readonly string[]).includes(p)),
];
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Short form — {SITE} — dev</title>
</head>
<body data-review-ui="shortform">
  <header class="er-masthead">
    <div class="er-masthead-kicker">
      {SITE}.org · short form
    </div>
    <h1 class="er-masthead-title">
      The <em>compositor</em>'s desk
    </h1>
    <p class="er-masthead-deck">
      Social copy, one galley slip per platform.
    </p>
    <div class="er-masthead-meta">
      <span>{cards.length} in flight</span>
      <span class="sep">·</span>
      <span>{orderedPlatforms.length} {orderedPlatforms.length === 1 ? 'platform' : 'platforms'}</span>
    </div>
  </header>

  <main class="er-container" style="padding-top: var(--er-space-4); padding-bottom: var(--er-space-6);">
    {cards.length === 0 ? (
      <div class="er-empty" style="margin-top: var(--er-space-5);">
        No short-form galleys on the desk.<br />
        Start one with <code>/editorial-shortform-draft --site {SITE} &lt;slug&gt; &lt;platform&gt;</code>
      </div>
    ) : (
      orderedPlatforms.map(platform => {
        const list = byPlatform.get(platform) ?? [];
        return (
          <section class="er-platform-section">
            <div class="er-platform-header">
              <h2>{platform}</h2>
              <span class="er-platform-count">№ {String(list.length).padStart(2, '0')}</span>
            </div>
            {list.map(({ workflow, currentVersion }) => (
              <article
                id={`workflow-${workflow.id}`}
                class="er-galley"
                data-platform={workflow.platform ?? 'other'}
                data-workflow-id={workflow.id}
                data-before-version={workflow.currentVersion}
                data-state={workflow.state}
              >
                <span class="er-galley-accent"></span>
                <header class="er-galley-head">
                  <h3>{workflow.slug}</h3>
                  {workflow.channel && <span class="channel">{workflow.channel}</span>}
                  <span class={`er-stamp er-stamp-${workflow.state}`}>{workflow.state.replace('-', ' ')}</span>
                  <span class="version">v{workflow.currentVersion}</span>
                </header>
                <textarea data-text>{currentVersion?.markdown ?? ''}</textarea>
                <div class="er-galley-actions">
                  <button type="button" class="er-btn er-btn-primary" data-action="save">Save as new version</button>
                  <button type="button" class="er-btn er-btn-approve" data-action="approve">Approve</button>
                  <button type="button" class="er-btn" data-action="iterate">Iterate</button>
                  <button type="button" class="er-btn er-btn-reject" data-action="reject">Reject</button>
                  <span style="font-family: var(--er-font-mono); font-size: 0.7rem; color: var(--er-faded); margin-left: auto;" data-hint></span>
                </div>
              </article>
            ))}
          </section>
        );
      })
    )}

    <p style="margin-top: var(--er-space-5); font-family: var(--er-font-display); font-style: italic; color: var(--er-faded);">
      <a href="/dev/editorial-studio">← back to the studio</a>
    </p>
  </main>

  <div class="er-toast" id="toast" hidden></div>
  <div class="er-poll-indicator" data-poll>auto-refresh · 10s</div>

  <script is:inline>
    (function () {
      const toast = document.getElementById('toast');
      function showToast(msg, isError) {
        toast.textContent = msg;
        toast.classList.toggle('error', !!isError);
        toast.hidden = false;
        setTimeout(() => { toast.hidden = true; }, 4000);
      }

      async function post(path, body) {
        const res = await fetch(path, {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify(body),
        });
        const json = await res.json();
        return { ok: res.ok, status: res.status, body: json };
      }

      async function ensureInReview(workflowId, currentState) {
        if (currentState !== 'open') return true;
        const r = await post('/api/dev/editorial-review/decision', {
          workflowId, to: 'in-review',
        });
        return r.ok;
      }

      // Focus the card referenced by ?focus= if any.
      const focusId = new URLSearchParams(location.search).get('focus');
      if (focusId) {
        const el = document.getElementById('workflow-' + focusId);
        if (el) {
          el.scrollIntoView({ behavior: 'smooth', block: 'center' });
          el.classList.add('focused');
        }
      }

      document.querySelectorAll('.er-galley').forEach((card) => {
        const workflowId = card.dataset.workflowId;
        const beforeVersion = parseInt(card.dataset.beforeVersion, 10);
        const state = card.dataset.state || 'open';
        const textarea = card.querySelector('[data-text]');
        const hint = card.querySelector('[data-hint]');
        const originalText = textarea.value;

        let lastTextInteraction = 0;
        textarea.addEventListener('input', () => { lastTextInteraction = Date.now(); });

        card.querySelector('[data-action="save"]').addEventListener('click', async () => {
          if (textarea.value === originalText) {
            showToast('No changes to save', true);
            return;
          }
          hint.textContent = 'Saving…';
          const r = await post('/api/dev/editorial-review/version', {
            workflowId, beforeVersion, afterMarkdown: textarea.value,
          });
          if (!r.ok) { showToast(r.body.error || 'Save failed', true); hint.textContent = ''; return; }
          showToast('Saved v' + r.body.version.version);
          window.location.reload();
        });

        card.querySelector('[data-action="approve"]').addEventListener('click', async () => {
          const bridged = await ensureInReview(workflowId, state);
          if (!bridged) { showToast('Could not transition to in-review', true); return; }
          await post('/api/dev/editorial-review/annotate', {
            type: 'approve', workflowId, version: beforeVersion,
          });
          const r = await post('/api/dev/editorial-review/decision', {
            workflowId, to: 'approved',
          });
          if (!r.ok) { showToast(r.body.error || 'Approve failed', true); return; }
          showToast('Approved. Run /editorial-approve in Claude Code.');
          setTimeout(() => window.location.reload(), 1500);
        });

        card.querySelector('[data-action="iterate"]').addEventListener('click', async () => {
          const bridged = await ensureInReview(workflowId, state);
          if (!bridged) { showToast('Could not transition to in-review', true); return; }
          const r = await post('/api/dev/editorial-review/decision', {
            workflowId, to: 'iterating',
          });
          if (!r.ok) { showToast(r.body.error || 'Iterate failed', true); return; }
          showToast('Run /editorial-iterate in Claude Code to draft v' + (beforeVersion + 1));
          setTimeout(() => window.location.reload(), 1500);
        });

        card.querySelector('[data-action="reject"]').addEventListener('click', async () => {
          const reason = window.prompt('Optional reason:') || '';
          if (reason) {
            await post('/api/dev/editorial-review/annotate', {
              type: 'reject', workflowId, version: beforeVersion, reason,
            });
          }
          const r = await post('/api/dev/editorial-review/decision', {
            workflowId, to: 'cancelled',
          });
          if (!r.ok) { showToast(r.body.error || 'Reject failed', true); return; }
          window.location.reload();
        });
      });

      // Polling: full reload every 10s if idle and no textarea has been edited
      let lastInteraction = Date.now();
      function bumpInteraction() { lastInteraction = Date.now(); }
      ['input', 'focus', 'keydown', 'mousedown'].forEach(ev => {
        document.addEventListener(ev, bumpInteraction, { passive: true, capture: true });
      });
      setInterval(() => {
        if (Date.now() - lastInteraction < 6000) return;
        // Also skip if any textarea has unsaved content
        for (const t of document.querySelectorAll('textarea[data-text]')) {
          const card = t.closest('.er-galley');
          const before = card ? card.dataset.beforeVersion : null;
          if (t.value !== t.defaultValue) return;
        }
        const ind = document.querySelector('[data-poll]');
        if (ind) ind.classList.add('polling');
        window.location.reload();
      }, 10000);
    })();
  </script>
</body>
</html>
