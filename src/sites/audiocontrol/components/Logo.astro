---
/**
 * audiocontrol logo — Service-Manual direction.
 *
 * Replaces the 80s-neon space-invader pixel art with a minimal amber
 * mark that reads as a character on a VFD display. Two variants:
 *
 *   - indicator: a small pulsing amber square — "instrument powered on".
 *     Default. Paired with the wordmark in the Header.
 *
 *   - glyph: a 5x5 pixel monogram ("A") rendered as a CSS grid of amber
 *     cells with a phosphor halo. For slots that need a tiny graphic
 *     identity (footer colophon, OG masthead).
 *
 * The wordmark itself lives in Header.astro, not here — this component
 * is purely the graphic mark.
 */

interface Props {
  variant?: 'indicator' | 'glyph';
  /** Edge length of the glyph/indicator in rem. Defaults 0.75 (indicator) / 1.5 (glyph). */
  size?: number;
  /** Visible label for screen readers. */
  label?: string;
}

const { variant = 'indicator', size, label = 'audiocontrol.org' } = Astro.props;

// 5x5 "A" pixel grid — '#' is an amber cell, '.' is empty.
const GLYPH = [
  '.###.',
  '#...#',
  '#####',
  '#...#',
  '#...#',
];
const glyphCells = GLYPH.flatMap((row) => row.split('').map((c) => c === '#'));

const indicatorSize = size ?? 0.75;
const glyphSize = size ?? 1.5;
---

{variant === 'indicator' && (
  <span
    class="logo-indicator"
    role="img"
    aria-label={label}
    style={`--indicator-size: ${indicatorSize}rem;`}
  />
)}

{variant === 'glyph' && (
  <span
    class="logo-glyph"
    role="img"
    aria-label={label}
    style={`--glyph-size: ${glyphSize}rem;`}
  >
    {glyphCells.map((on) => (
      <span class={on ? 'cell on' : 'cell'} aria-hidden="true"></span>
    ))}
  </span>
)}

<style>
  .logo-indicator {
    display: inline-block;
    width: var(--indicator-size);
    height: var(--indicator-size);
    background: hsl(var(--primary));
    box-shadow:
      0 0 10px hsl(var(--primary) / 0.6),
      0 0 2px hsl(var(--primary) / 0.9);
    animation: indicator-pulse 2.6s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes indicator-pulse {
    0%, 100% {
      opacity: 0.65;
      box-shadow: 0 0 6px hsl(var(--primary) / 0.4);
    }
    50% {
      opacity: 1;
      box-shadow:
        0 0 14px hsl(var(--primary) / 0.75),
        0 0 3px hsl(var(--primary) / 0.9);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .logo-indicator {
      animation: none;
      opacity: 0.95;
    }
  }

  .logo-glyph {
    display: inline-grid;
    grid-template-columns: repeat(5, 1fr);
    grid-template-rows: repeat(5, 1fr);
    width: var(--glyph-size);
    height: var(--glyph-size);
    gap: 1px;
    flex-shrink: 0;
    filter: drop-shadow(0 0 6px hsl(var(--primary) / 0.35));
  }

  .logo-glyph .cell {
    background: transparent;
  }

  .logo-glyph .cell.on {
    background: hsl(var(--primary));
  }
</style>
