---
/**
 * ProjectCard — Service-Manual treatment.
 *
 * Reads as a front-panel product callout rather than a flat link card:
 *   - Panel-label "STATUS: AVAILABLE / PENDING" instead of a colored pill.
 *   - Optional spec-meta line under the title ("1987 · 16-VOICE · 12-BIT")
 *     that sets the device in its era and capability without requiring a
 *     full paragraph.
 *   - Dimension-bracket corners on available cards — a subtle technical
 *     callout device taken from the service-manual vocabulary.
 *   - Amber CTA line "→ OPEN EDITOR" on hover; coming-soon cards stay
 *     subdued.
 */

interface Props {
  name: string;
  description: string;
  status: 'available' | 'coming-soon';
  href?: string;
  image?: string;
  /** Terse spec line rendered under the title. Example: "1987 · 16-VOICE · 12-BIT". */
  meta?: string;
}

const { name, description, status, href, image, meta } = Astro.props;

const isAvailable = status === 'available';
const Tag = isAvailable ? 'a' : 'div';
const statusLabel = isAvailable ? 'Available' : 'Pending';
const cta = isAvailable ? 'Open Editor' : 'In development';
---

<Tag
  class:list={['project-card', { 'is-available': isAvailable, 'is-coming-soon': !isAvailable, 'has-image': !!image }]}
  href={isAvailable ? href : undefined}
>
  {isAvailable && (
    <>
      <span class="corner corner-tl" aria-hidden="true"></span>
      <span class="corner corner-tr" aria-hidden="true"></span>
      <span class="corner corner-bl" aria-hidden="true"></span>
      <span class="corner corner-br" aria-hidden="true"></span>
    </>
  )}

  {image && (
    <div class="card-image">
      <img src={image} alt="" loading="lazy" />
    </div>
  )}

  <div class="card-body">
    <p class="card-status">
      <span class="card-status-label">Status</span>
      <span class="card-status-value">{statusLabel}</span>
    </p>
    <h3 class="card-title">{name}</h3>
    {meta && <p class="card-meta">{meta}</p>}
    <p class="card-description">{description}</p>
    <p class="card-cta" aria-hidden="true">
      <span class="card-cta-arrow">→</span>
      <span class="card-cta-text">{cta}</span>
    </p>
  </div>
</Tag>

<style>
  .project-card {
    display: block;
    position: relative;
    background: hsl(var(--card));
    border: 1px solid hsl(var(--border));
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    transition:
      border-color 0.3s ease,
      background-color 0.3s ease,
      box-shadow 0.3s ease,
      transform 0.2s ease;
  }

  .project-card:not(.has-image) {
    padding: 1.5rem;
  }

  .card-image {
    width: 100%;
    height: 11rem;
    overflow: hidden;
    position: relative;
  }

  .card-image::after {
    /* Soft warm overlay to tie all screenshots into the palette. */
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 55%, hsl(var(--card)) 100%);
    pointer-events: none;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .project-card.is-available:hover .card-image img {
    transform: scale(1.03);
  }

  .card-body {
    padding: 1.5rem 1.5rem 1.25rem;
  }

  .project-card.has-image .card-body {
    padding-top: 1rem;
  }

  .project-card.is-available {
    cursor: pointer;
  }

  .project-card.is-available:hover,
  .project-card.is-available:focus-visible {
    border-color: hsl(var(--primary) / 0.55);
    background: hsl(var(--card-hover));
    box-shadow: var(--card-glow-hover);
    transform: translateY(-2px);
    outline: none;
  }

  .project-card.is-coming-soon {
    opacity: 0.62;
    cursor: default;
  }

  /* --- Status panel-label ------------------------------------------ */

  .card-status {
    font-family: var(--font-display);
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: hsl(var(--muted-foreground));
    margin: 0 0 0.75rem 0;
    display: inline-flex;
    gap: 0.4rem;
    align-items: center;
  }

  .card-status-label::after {
    content: ':';
    padding-left: 0.1em;
  }

  .project-card.is-available .card-status-value {
    color: hsl(var(--primary));
    text-shadow: 0 0 8px hsl(var(--primary) / 0.35);
  }

  .project-card.is-coming-soon .card-status-value {
    color: hsl(var(--muted-foreground));
  }

  /* --- Title + meta + description ---------------------------------- */

  .card-title {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 400;
    letter-spacing: 0;
    line-height: 1.2;
    margin: 0;
    color: hsl(var(--foreground));
  }

  .card-meta {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: hsl(var(--muted-foreground));
    margin: 0.5rem 0 0 0;
  }

  .card-description {
    font-size: 0.92rem;
    color: hsl(var(--muted-foreground));
    line-height: 1.55;
    margin: 0.85rem 0 0 0;
  }

  /* --- CTA --------------------------------------------------------- */

  .card-cta {
    font-family: var(--font-display);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: hsl(var(--muted-foreground));
    margin: 1.25rem 0 0 0;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .project-card.is-available .card-cta-arrow {
    color: hsl(var(--primary));
  }

  .project-card.is-available:hover .card-cta {
    color: hsl(var(--foreground));
  }

  .project-card.is-available:hover .card-cta-arrow {
    transform: translateX(3px);
  }

  /* --- Dimension-bracket corners (available cards only) ----------- */

  .corner {
    position: absolute;
    width: 14px;
    height: 14px;
    border-color: hsl(var(--primary) / 0.5);
    border-style: solid;
    border-width: 0;
    transition: border-color 0.3s ease;
    pointer-events: none;
    z-index: 2;
  }

  .corner-tl {
    top: 8px;
    left: 8px;
    border-top-width: 2px;
    border-left-width: 2px;
  }

  .corner-tr {
    top: 8px;
    right: 8px;
    border-top-width: 2px;
    border-right-width: 2px;
  }

  .corner-bl {
    bottom: 8px;
    left: 8px;
    border-bottom-width: 2px;
    border-left-width: 2px;
  }

  .corner-br {
    bottom: 8px;
    right: 8px;
    border-bottom-width: 2px;
    border-right-width: 2px;
  }

  .project-card.is-available:hover .corner {
    border-color: hsl(var(--primary) / 0.9);
  }
</style>
