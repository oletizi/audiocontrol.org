---
import Layout from './Layout.astro';
import '../styles/prose.css';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  frontmatter?: {
    title: string;
    description?: string;
  };
  headings?: Heading[];
  title?: string;
  description?: string;
}

const { frontmatter, headings = [], title: directTitle, description: directDescription } = Astro.props;
const title = frontmatter?.title ?? directTitle ?? 'Documentation';
const description = frontmatter?.description ?? directDescription;

const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const ogImageSlug = pathSegments.join('-');
const ogImage = `/images/og/${ogImageSlug}.png`;

const tocHeadings = headings.filter((h) => h.depth === 2);
---

<Layout title={title} description={description} image={ogImage}>
  <div class="article-layout">
    {tocHeadings.length > 0 && (
      <aside class="toc" aria-label="Table of contents">
        <p class="toc-header">In this article</p>
        <nav>
          {tocHeadings.map((heading) => (
            <a href={`#${heading.slug}`} class="toc-link">{heading.text}</a>
          ))}
        </nav>
      </aside>
    )}
    <article class="prose prose--wide docs-article">
      <slot />
    </article>
  </div>
</Layout>

<style>
  .article-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 1024px) {
    .article-layout {
      grid-template-columns: 220px 1fr;
    }
  }

  .toc {
    display: none;
  }

  @media (min-width: 1024px) {
    .toc {
      display: block;
      position: sticky;
      top: 5rem;
      align-self: start;
      max-height: calc(100vh - 6rem);
      overflow-y: auto;
    }
  }

  .toc-header {
    font-family: var(--font-display);
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: hsl(var(--muted-foreground));
    margin: 0 0 1rem 0;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid hsl(var(--border));
  }

  .toc-link {
    display: block;
    color: hsl(var(--muted-foreground));
    text-decoration: none;
    font-size: 0.85rem;
    line-height: 1.4;
    padding: 0.4rem 0 0.4rem 0.75rem;
    border-left: 2px solid transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .toc-link:hover,
  .toc-link.active {
    color: hsl(var(--foreground));
    border-left-color: hsl(var(--primary));
  }

  .docs-article {
    min-width: 0;
  }
</style>

<script>
  const tocLinks = document.querySelectorAll('.toc-link');
  const headings = document.querySelectorAll('.docs-article h2');

  if (tocLinks.length > 0 && headings.length > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            tocLinks.forEach((link) => link.classList.remove('active'));
            const activeLink = document.querySelector(`.toc-link[href="#${entry.target.id}"]`);
            if (activeLink) {
              activeLink.classList.add('active');
            }
          }
        });
      },
      {
        rootMargin: '-80px 0px -80% 0px',
        threshold: 0,
      },
    );

    headings.forEach((heading) => observer.observe(heading));
  }
</script>
