---
import Layout from './Layout.astro';
import '../styles/prose.css';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  frontmatter?: {
    title: string;
    description?: string;
    date?: string;
    datePublished?: string;
    dateModified?: string;
    author?: string;
    image?: string;
    socialImage?: string;
  };
  headings?: Heading[];
  title?: string;
  description?: string;
  date?: string;
  datePublished?: string;
  dateModified?: string;
  author?: string;
}

const {
  frontmatter,
  headings = [],
  title: directTitle,
  description: directDescription,
  date: directDate,
  datePublished: directDatePublished,
  dateModified: directDateModified,
  author: directAuthor,
} = Astro.props;
const title = frontmatter?.title ?? directTitle ?? 'Blog';
const description = frontmatter?.description ?? directDescription;
const date = frontmatter?.date ?? directDate;
const datePublished = frontmatter?.datePublished ?? directDatePublished;
const dateModified = frontmatter?.dateModified ?? directDateModified ?? datePublished;
const author = frontmatter?.author ?? directAuthor ?? 'audiocontrol.org';

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Generate auto-discovered OG image path from URL: /blog/my-post/ → /images/og/blog-my-post.png
const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const ogImageSlug = pathSegments.join('-');
const autoOgImage = `/images/og/${ogImageSlug}.png`;
// `image` is for inline display only. `socialImage` overrides the OG/sharing image.
const featureImage = frontmatter?.image;
const socialImage = frontmatter?.socialImage ?? autoOgImage;
const schemaImage = new URL(socialImage, Astro.site).toString();

const blogPostingJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description: description,
  datePublished: datePublished,
  dateModified: dateModified,
  author: {
    '@type': 'Person',
    name: author,
  },
  publisher: {
    '@type': 'Organization',
    name: 'audiocontrol.org',
    logo: {
      '@type': 'ImageObject',
      url: 'https://audiocontrol.org/favicon.svg',
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalURL.toString(),
  },
  image: schemaImage,
};

const tocHeadings = headings.filter((h) => h.depth === 2);
---

<Layout title={title} description={description} image={socialImage} type="article" jsonLd={blogPostingJsonLd}>
  <div class="article-layout">
    {tocHeadings.length > 0 && (
      <aside class="toc" aria-label="Table of contents">
        <p class="toc-header">In this article</p>
        <nav>
          {tocHeadings.map((heading) => (
            <a href={`#${heading.slug}`} class="toc-link">{heading.text}</a>
          ))}
        </nav>
      </aside>
    )}
    <article class="prose blog-article">
      {date && (
        <p class="post-meta">
          <span class="post-meta-date">{date}</span>
          {author && <span class="post-meta-sep" aria-hidden="true">·</span>}
          {author && <span class="post-meta-author">{author}</span>}
        </p>
      )}
      {featureImage && (
        <figure class="post-feature-image">
          <img src={featureImage} alt="" />
        </figure>
      )}
      <slot />
    </article>
  </div>
</Layout>

<style>
  .article-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 1024px) {
    .article-layout {
      grid-template-columns: 220px 1fr;
    }
  }

  .toc {
    display: none;
  }

  @media (min-width: 1024px) {
    .toc {
      display: block;
      position: sticky;
      top: 5rem;
      align-self: start;
      max-height: calc(100vh - 6rem);
      overflow-y: auto;
    }
  }

  .toc-header {
    font-family: var(--font-display);
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: hsl(var(--muted-foreground));
    margin: 0 0 1rem 0;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid hsl(var(--border));
  }

  .toc-link {
    display: block;
    color: hsl(var(--muted-foreground));
    text-decoration: none;
    font-size: 0.85rem;
    line-height: 1.4;
    padding: 0.4rem 0 0.4rem 0.75rem;
    border-left: 2px solid transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .toc-link:hover,
  .toc-link.active {
    color: hsl(var(--foreground));
    border-left-color: hsl(var(--primary));
  }

  .blog-article {
    min-width: 0;
  }

  .post-meta {
    font-family: var(--font-display);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: hsl(var(--muted-foreground));
    margin: 0 0 2rem 0;
    display: inline-flex;
    gap: 0.6rem;
    align-items: center;
  }

  .post-meta-sep {
    opacity: 0.5;
  }

  .post-meta-author {
    color: hsl(var(--primary));
  }
</style>

<script>
  const tocLinks = document.querySelectorAll('.toc-link');
  const headings = document.querySelectorAll('.blog-article h2');

  if (tocLinks.length > 0 && headings.length > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            tocLinks.forEach((link) => link.classList.remove('active'));
            const activeLink = document.querySelector(`.toc-link[href="#${entry.target.id}"]`);
            if (activeLink) {
              activeLink.classList.add('active');
            }
          }
        });
      },
      {
        rootMargin: '-80px 0px -80% 0px',
        threshold: 0,
      },
    );

    headings.forEach((heading) => observer.observe(heading));
  }
</script>
