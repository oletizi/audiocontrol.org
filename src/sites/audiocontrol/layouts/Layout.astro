---
import '../styles/design-tokens.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  jsonLd?: Record<string, unknown>;
}

const {
  title = 'audiocontrol.org',
  description = 'Open source web interfaces for vintage samplers and synthesizers.',
  image = '/images/og-image.png',
  type = 'website',
  jsonLd: customJsonLd,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const imageURL = new URL(image, Astro.site);

const defaultJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'audiocontrol.org',
  url: 'https://audiocontrol.org',
  logo: 'https://audiocontrol.org/favicon.svg',
  description: 'Open source web interfaces for vintage samplers and synthesizers.',
  sameAs: [
    'https://github.com/audiocontrol-org'
  ]
};

const jsonLd = customJsonLd ?? defaultJsonLd;
---

<html lang="en">
  <head>
    <!-- Google Tag Manager -->
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-NDFVKW82');</script>
    <!-- End Google Tag Manager -->

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="preload" href="/fonts/departure-mono-regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/ibm-plex-sans-400.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/ibm-plex-sans-600.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageURL} />
    <meta property="og:site_name" content="audiocontrol.org" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageURL} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Umami Analytics -->
    <script defer src="https://cloud.umami.is/script.js" data-website-id="2b9a4087-e93a-432d-adba-252233404d67"></script>

    <style>
      /* Departure Mono + IBM Plex Sans @font-face live in design-tokens.css. */

      :global(h1), :global(h2), :global(h3), :global(h4), :global(h5), :global(h6) {
        font-family: var(--font-heading);
        font-weight: 400;
        letter-spacing: 0.01em;
        line-height: 1.15;
      }

      :global(h3), :global(h4), :global(h5), :global(h6) {
        /* Smaller headings read better in the body face at weight 600
         * than in Departure Mono at small pixel sizes. */
        font-family: var(--font-body);
        font-weight: 600;
        letter-spacing: 0;
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      html {
        font-family: var(--font-body);
        font-size: 16px;
        color: hsl(var(--foreground));
        scrollbar-gutter: stable;
      }

      body {
        min-height: 100vh;
        margin: 0;
        width: 100%;
        position: relative;
      }

      h1, h2, p {
        margin: 0;
      }

      a {
        color: hsl(var(--primary));
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }

      /* Ensure content stacks above the atmosphere overlays. */
      :global(header),
      :global(main),
      :global(footer) {
        position: relative;
        z-index: 3;
      }

      /* Selection uses phosphor amber. */
      :global(::selection) {
        background: hsl(var(--primary) / 0.35);
        color: hsl(var(--foreground));
      }
    </style>
    <slot name="head" />
  </head>
  <body class="atmosphere-vignette atmosphere-grain atmosphere-scanlines">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-NDFVKW82"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->

    <Header />

    <div class="site-container">
      <main>
        <slot />
      </main>

      <Footer />
    </div>
  </body>
</html>
