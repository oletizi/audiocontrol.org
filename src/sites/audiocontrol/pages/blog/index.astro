---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const entries = await getCollection('blog', ({ data }) =>
  import.meta.env.PROD ? data.state === 'published' : true,
);

const blogPosts = entries
  .map((entry) => ({
    ...entry.data,
    slug: entry.id,
  }))
  .sort((a, b) => b.datePublished.localeCompare(a.datePublished));

const formatBlogDate = (dateStr: string): string => {
  const date = new Date(dateStr + 'T00:00:00');
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
};
---

<Layout
  title="Blog — audiocontrol.org"
  description="Articles about vintage samplers, synthesizers, and open source audio tools."
  image="/images/og/index.png"
>
  <header class="page-header">
    <p class="panel-label">Blog</p>
    <h1 class="page-title">Notes from the workbench.</h1>
    <p class="page-note">
      Reverse-engineering, protocol archaeology, and working with AI coding
      agents on long-horizon firmware and editor projects.
    </p>
    <hr class="rule-ticked" />
  </header>

  <ul class="blog-grid">
    {blogPosts.map((post) => (
      <li class="blog-card-wrap">
        <a href={`/blog/${post.slug}/`} class="blog-card">
          <article class="blog-card-inner">
            {post.image && (
              <div class="blog-card-image">
                <img src={post.image} alt="" loading="lazy" />
              </div>
            )}
            <div class="blog-card-content">
              <p class="blog-card-meta">
                <time class="blog-card-date" datetime={post.datePublished}>
                  {formatBlogDate(post.datePublished)}
                </time>
              </p>
              <h2 class="blog-card-title">{post.title}</h2>
              <p class="blog-card-description">{post.description}</p>
              {post.tags && post.tags.length > 0 && (
                <ul class="blog-card-tags">
                  {post.tags.map((tag) => (
                    <li class="tag">{tag}</li>
                  ))}
                </ul>
              )}
            </div>
          </article>
        </a>
      </li>
    ))}
  </ul>
</Layout>

<style>
  .page-header {
    padding: 2.5rem 0 1.5rem;
    max-width: 46rem;
  }

  .page-header .panel-label {
    margin: 0 0 0.75rem 0;
  }

  .page-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.4vw, 2.5rem);
    font-weight: 400;
    line-height: 1.2;
    color: hsl(var(--foreground));
    margin: 0 0 0.85rem 0;
  }

  .page-note {
    font-size: 1rem;
    color: hsl(var(--muted-foreground));
    line-height: 1.55;
    margin: 0 0 1.75rem 0;
  }

  .page-header .rule-ticked {
    margin-top: 0;
  }

  .blog-grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 1fr;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  @media (min-width: 900px) {
    .blog-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .blog-card-wrap {
    display: block;
  }

  .blog-card {
    display: block;
    text-decoration: none;
    color: inherit;
    border: 1px solid hsl(var(--border));
    background: hsl(var(--card));
    overflow: hidden;
    transition: border-color 0.25s ease, background 0.25s ease, transform 0.2s ease, box-shadow 0.25s ease;
    height: 100%;
  }

  .blog-card:hover {
    border-color: hsl(var(--primary) / 0.5);
    background: hsl(var(--card-hover));
    box-shadow: var(--card-glow-hover);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .blog-card:hover .blog-card-title {
    color: hsl(var(--primary));
  }

  .blog-card:hover .blog-card-image img {
    transform: scale(1.04);
  }

  .blog-card-inner {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .blog-card-image {
    width: 100%;
    height: 12rem;
    overflow: hidden;
    flex-shrink: 0;
    position: relative;
  }

  .blog-card-image::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 60%, hsl(var(--card)) 100%);
    pointer-events: none;
  }

  .blog-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .blog-card-content {
    padding: 1.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .blog-card-meta {
    font-family: var(--font-display);
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: hsl(var(--muted-foreground));
    margin: 0;
  }

  .blog-card-title {
    font-family: var(--font-body);
    font-size: 1.15rem;
    font-weight: 600;
    color: hsl(var(--foreground));
    margin: 0;
    transition: color 0.2s ease;
    line-height: 1.35;
  }

  .blog-card-description {
    font-size: 0.92rem;
    color: hsl(var(--muted-foreground));
    line-height: 1.55;
    margin: 0;
    flex: 1;
  }

  .blog-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 0 0;
  }

  .tag {
    font-family: var(--font-display);
    font-size: 0.64rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: hsl(var(--muted-foreground));
    background: transparent;
    border: 1px solid hsl(var(--border));
    padding: 0.2rem 0.55rem;
  }
</style>
