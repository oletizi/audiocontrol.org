---
import Layout from '../../layouts/Layout.astro';
import { blogPosts, formatBlogDate } from '../../data/blog-posts';

const formatDate = formatBlogDate;
---

<Layout
  title="Blog — audiocontrol.org"
  description="Articles about vintage samplers, synthesizers, and open source audio tools."
  image="/images/og/index.png"
>
  <section class="blog-header">
    <h2 class="section-label">Blog</h2>
    <div class="section-line"></div>
  </section>

  <div class="blog-grid">
    {blogPosts.map((post) => (
      <a href={`/blog/${post.slug}/`} class="blog-card">
        <article class="blog-card-inner">
          {post.image && (
            <div class="blog-card-image">
              <img src={post.image} alt="" loading="lazy" />
            </div>
          )}
          <div class="blog-card-content">
            <div class="blog-card-header">
              <h3 class="blog-card-title">{post.title}</h3>
              <time class="blog-card-date" datetime={post.datePublished}>
                {formatDate(post.datePublished)}
              </time>
            </div>
            <p class="blog-card-description">{post.description}</p>
            {post.tags && post.tags.length > 0 && (
              <div class="blog-card-tags">
                {post.tags.map((tag, i) => (
                  <span class="tag" key={i}>{tag}</span>
                ))}
              </div>
            )}
          </div>
        </article>
      </a>
    ))}
  </div>
</Layout>

<style>
  .blog-header {
    margin-bottom: 2.5rem;
  }

  .section-label {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.875rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: hsl(var(--muted-foreground));
    margin: 0 0 0.5rem 0;
  }

  .section-line {
    height: 1px;
    width: 6rem;
    background: linear-gradient(to right, hsl(var(--accent) / 0.4), transparent);
  }

  .blog-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 1024px) {
    .blog-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .blog-card {
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: 0.5rem;
    border: 1px solid hsl(var(--border));
    background: hsl(var(--card));
    overflow: hidden;
    transition: all 0.3s ease;
    box-shadow: var(--card-glow);
  }

  .blog-card:hover {
    box-shadow: var(--card-glow-hover);
    text-decoration: none;
  }

  .blog-card:hover .blog-card-title {
    color: hsl(var(--primary));
  }

  .blog-card:hover .blog-card-image img {
    transform: scale(1.05);
  }

  .blog-card-inner {
    display: flex !important;
    flex-direction: column !important;
    height: 100%;
  }

  .blog-card-image {
    width: 100%;
    height: 11rem;
    overflow: hidden;
    flex-shrink: 0;
  }

  .blog-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .blog-card-content {
    padding: 1.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .blog-card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .blog-card-title {
    font-family: "JetBrains Mono", monospace;
    font-size: 1.125rem;
    font-weight: 600;
    color: hsl(var(--foreground));
    margin: 0;
    transition: color 0.2s ease;
    line-height: 1.4;
  }

  .blog-card-date {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.75rem;
    color: hsl(var(--muted-foreground));
    white-space: nowrap;
    flex-shrink: 0;
  }

  .blog-card-description {
    font-size: 0.875rem;
    color: hsl(var(--muted-foreground));
    line-height: 1.6;
    margin: 0 0 1rem 0;
    flex: 1;
  }

  .blog-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    display: inline-block;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.75rem;
    color: hsl(var(--muted-foreground));
    background: hsl(var(--background));
    border: 1px solid hsl(var(--border));
    border-radius: 9999px;
    padding: 0.125rem 0.625rem;
    margin-right: 0.5rem;
    margin-bottom: 0.25rem;
  }

  .tag:last-child {
    margin-right: 0;
  }
</style>
