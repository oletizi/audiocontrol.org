---
import Layout from '../../layouts/Layout.astro';
import ProjectCard from '../../components/ProjectCard.astro';

interface Editor {
  name: string;
  description: string;
  status: 'available' | 'coming-soon';
  meta: string;
  slug?: string;
  image?: string;
}

const editors: Editor[] = [
  {
    name: "Roland S-330",
    description: "Web-based patch editor for the Roland S-330 12-bit sampler. Edit tones, patches, and performance settings directly in your browser via Web MIDI.",
    status: "available",
    meta: "12-bit · Web MIDI · Live sync",
    slug: "/roland/s330/editor",
    image: "/images/s330-screenshot.png",
  },
  {
    name: "Roland S-550",
    description: "Web-based editor for the Roland S-550 12-bit sampler. Shares the editor UI with the S-330 with an expanded feature set.",
    status: "available",
    meta: "12-bit · Web MIDI",
    slug: "/roland/s550/editor",
  },
  {
    name: "Akai S3000XL",
    description: "Web-based editor for the Akai S3000XL sampler. Edit programs, keygroups, and samples via MIDI-over-SCSI.",
    status: "coming-soon",
    meta: "16-bit · MIDI-over-SCSI",
  },
  {
    name: "Akai S5000",
    description: "Web-based editor for the Akai S5000/S6000 series samplers — 24-bit audio and USB transfer.",
    status: "coming-soon",
    meta: "24-bit · USB · SCSI",
  },
  {
    name: "Roland JV-1080",
    description: "Web-based patch editor for the Roland JV-1080 synthesizer module with expansion board support.",
    status: "coming-soon",
    meta: "Synth module · SysEx",
  },
];

const available = editors.filter((e) => e.status === 'available');
const pending = editors.filter((e) => e.status === 'coming-soon');
---

<Layout
  title="Editors — audiocontrol.org"
  description="Free, open source web-based editors for vintage samplers and synthesizers."
  image="/images/og/index.png"
>
  <header class="page-header">
    <p class="panel-label">Editors</p>
    <h1 class="page-title">Web editors for the rack.</h1>
    <p class="page-note">
      Open source browser editors for vintage Roland and Akai samplers and
      synthesizers. No install, no vendor lock, every byte of the SysEx is
      on GitHub.
    </p>
    <hr class="rule-ticked" />
  </header>

  <section class="block" aria-labelledby="available-label">
    <header class="block-header">
      <h2 id="available-label" class="panel-label panel-label--accent">Available Now</h2>
      <p class="block-note">Editors you can open in a browser today.</p>
    </header>
    <div class="projects-grid projects-grid--featured">
      {available.map((editor) => (
        <ProjectCard
          name={editor.name}
          description={editor.description}
          status={editor.status}
          href={editor.slug}
          image={editor.image}
          meta={editor.meta}
        />
      ))}
    </div>
  </section>

  <section class="block" aria-labelledby="pending-label">
    <header class="block-header">
      <h2 id="pending-label" class="panel-label">In Development</h2>
      <p class="block-note">Devices on the workbench. Follow the GitHub org for progress.</p>
    </header>
    <div class="projects-grid projects-grid--small">
      {pending.map((editor) => (
        <ProjectCard
          name={editor.name}
          description={editor.description}
          status={editor.status}
          meta={editor.meta}
        />
      ))}
    </div>
  </section>
</Layout>

<style>
  .page-header {
    padding: 2.5rem 0 1.5rem;
    max-width: 46rem;
  }

  .page-header .panel-label {
    margin: 0 0 0.75rem 0;
  }

  .page-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.4vw, 2.5rem);
    font-weight: 400;
    line-height: 1.2;
    color: hsl(var(--foreground));
    margin: 0 0 0.85rem 0;
  }

  .page-note {
    font-size: 1rem;
    color: hsl(var(--muted-foreground));
    line-height: 1.55;
    margin: 0 0 1.75rem 0;
  }

  .block {
    padding: 1.75rem 0 2.5rem;
  }

  .block-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin: 0 0 1.5rem 0;
    flex-wrap: wrap;
  }

  .block-header .panel-label {
    margin: 0;
  }

  .block-note {
    font-size: 0.9rem;
    color: hsl(var(--muted-foreground));
    margin: 0;
  }

  .projects-grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 720px) {
    .projects-grid--featured {
      grid-template-columns: repeat(2, 1fr);
    }
    .projects-grid--small {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
