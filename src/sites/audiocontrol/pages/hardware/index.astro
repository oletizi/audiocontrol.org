---
import Layout from '../../layouts/Layout.astro';

interface Device {
  name: string;
  description: string;
  year: string;
  format: string;
  slug: string;
  image?: string;
  tags?: string[];
}

const devices: Device[] = [
  {
    name: "Roland S-330",
    description: "1U rack-mount 12-bit sampler with 16-voice polyphony, resonant filters, and graphical editing via external monitor.",
    year: "1987",
    format: "1U Rack",
    slug: "/roland/s330/",
    image: "/images/s-330-feature.jpg",
    tags: ["12-bit", "Rack", "S-Series"],
  },
  {
    name: "Roland S-550",
    description: "Full-featured 2U rack sampler with expanded memory, RGB monitor output, and the same 12-bit sound engine as the S-330.",
    year: "1987",
    format: "2U Rack",
    slug: "/roland/s550/",
    tags: ["12-bit", "Rack", "S-Series"],
  },
  {
    name: "Roland S-770",
    description: "Roland's flagship 16-bit stereo sampler with 24-voice polyphony, S/PDIF digital I/O, and high-resolution color display.",
    year: "1990",
    format: "3U Rack",
    slug: "/roland/s770/",
    tags: ["16-bit", "Rack", "S-Series"],
  },
  {
    name: "Roland W-30",
    description: "Sampling workstation combining the S-330's 12-bit engine with a 61-key keyboard and built-in sequencer.",
    year: "1989",
    format: "Workstation",
    slug: "/roland/w30/",
    tags: ["12-bit", "Keyboard", "S-Series"],
  },
];
---

<Layout
  title="Hardware — audiocontrol.org"
  description="Vintage samplers and synthesizers supported by audiocontrol.org open source editors."
  image="/images/og/index.png"
>
  <header class="page-header">
    <p class="panel-label">Hardware Catalog</p>
    <h1 class="page-title">The rack units we write software for.</h1>
    <p class="page-note">
      Reference pages for every sampler and synthesizer the audiocontrol
      editors target — specs, quirks, companion peripherals, and a pointer
      to the editor (when one exists).
    </p>
    <hr class="rule-ticked" />
  </header>

  <ul class="hardware-grid">
    {devices.map((device) => (
      <li>
        <a href={device.slug} class="hardware-card">
          <article class="hardware-card-inner">
            {device.image && (
              <div class="hardware-card-image">
                <img src={device.image} alt="" loading="lazy" />
              </div>
            )}
            <div class="hardware-card-content">
              <p class="hardware-card-meta">
                <span class="meta-year">{device.year}</span>
                <span class="meta-sep" aria-hidden="true">·</span>
                <span class="meta-format">{device.format}</span>
              </p>
              <h2 class="hardware-card-title">{device.name}</h2>
              <p class="hardware-card-description">{device.description}</p>
              {device.tags && device.tags.length > 0 && (
                <ul class="hardware-card-tags">
                  {device.tags.map((tag) => (
                    <li class="tag">{tag}</li>
                  ))}
                </ul>
              )}
            </div>
          </article>
        </a>
      </li>
    ))}
  </ul>
</Layout>

<style>
  .page-header {
    padding: 2.5rem 0 1.5rem;
    max-width: 46rem;
  }

  .page-header .panel-label {
    margin: 0 0 0.75rem 0;
  }

  .page-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.4vw, 2.5rem);
    font-weight: 400;
    line-height: 1.2;
    color: hsl(var(--foreground));
    margin: 0 0 0.85rem 0;
  }

  .page-note {
    font-size: 1rem;
    color: hsl(var(--muted-foreground));
    line-height: 1.55;
    margin: 0 0 1.75rem 0;
  }

  .hardware-grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 1fr;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  @media (min-width: 900px) {
    .hardware-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .hardware-card {
    display: block;
    text-decoration: none;
    color: inherit;
    border: 1px solid hsl(var(--border));
    background: hsl(var(--card));
    overflow: hidden;
    height: 100%;
    transition: border-color 0.25s ease, background 0.25s ease, transform 0.2s ease, box-shadow 0.25s ease;
  }

  .hardware-card:hover {
    border-color: hsl(var(--primary) / 0.55);
    background: hsl(var(--card-hover));
    box-shadow: var(--card-glow-hover);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .hardware-card:hover .hardware-card-title {
    color: hsl(var(--primary));
  }

  .hardware-card:hover .hardware-card-image img {
    transform: scale(1.04);
  }

  .hardware-card-inner {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .hardware-card-image {
    width: 100%;
    height: 11rem;
    overflow: hidden;
    flex-shrink: 0;
    position: relative;
  }

  .hardware-card-image::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 60%, hsl(var(--card)) 100%);
    pointer-events: none;
  }

  .hardware-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .hardware-card-content {
    padding: 1.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .hardware-card-meta {
    font-family: var(--font-display);
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: hsl(var(--muted-foreground));
    margin: 0;
    display: inline-flex;
    gap: 0.5rem;
  }

  .meta-format {
    color: hsl(var(--primary));
  }

  .meta-sep {
    opacity: 0.5;
  }

  .hardware-card-title {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 400;
    color: hsl(var(--foreground));
    margin: 0;
    line-height: 1.2;
    transition: color 0.2s ease;
  }

  .hardware-card-description {
    font-size: 0.92rem;
    color: hsl(var(--muted-foreground));
    line-height: 1.55;
    margin: 0;
    flex: 1;
  }

  .hardware-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
    padding: 0;
    margin: 0.35rem 0 0 0;
  }

  .tag {
    font-family: var(--font-display);
    font-size: 0.64rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: hsl(var(--muted-foreground));
    background: transparent;
    border: 1px solid hsl(var(--border));
    padding: 0.2rem 0.55rem;
  }
</style>
