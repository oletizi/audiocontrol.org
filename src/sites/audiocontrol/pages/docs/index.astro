---
import Layout from '../../layouts/Layout.astro';

interface DocEntry {
  title: string;
  description: string;
  slug: string;
  category: string;
  tags?: string[];
}

const docs: DocEntry[] = [
  {
    title: "Roland S-330 Web Editor Guide",
    description: "Complete documentation for the S-330 web editor including setup, MIDI configuration, and feature reference.",
    slug: "/docs/roland/samplers/s-330/",
    category: "Editor Guide",
    tags: ["Roland", "S-330", "Editor"],
  },
];
---

<Layout
  title="Documentation — audiocontrol.org"
  description="Documentation and guides for audiocontrol.org open source audio tools."
  image="/images/og/index.png"
>
  <header class="page-header">
    <p class="panel-label">Documentation</p>
    <h1 class="page-title">Operation guides for every editor.</h1>
    <p class="page-note">
      Setup, MIDI configuration, and feature reference for the audiocontrol
      editors — written to pair with the device pages you'd reach for in
      the physical rack.
    </p>
    <hr class="rule-ticked" />
  </header>

  <ul class="docs-grid">
    {docs.map((doc) => (
      <li>
        <a href={doc.slug} class="docs-card">
          <article class="docs-card-inner">
            <p class="docs-card-meta">
              <span class="meta-category">{doc.category}</span>
            </p>
            <h2 class="docs-card-title">{doc.title}</h2>
            <p class="docs-card-description">{doc.description}</p>
            {doc.tags && doc.tags.length > 0 && (
              <ul class="docs-card-tags">
                {doc.tags.map((tag) => (
                  <li class="tag">{tag}</li>
                ))}
              </ul>
            )}
          </article>
        </a>
      </li>
    ))}
  </ul>
</Layout>

<style>
  .page-header {
    padding: 2.5rem 0 1.5rem;
    max-width: 46rem;
  }

  .page-header .panel-label {
    margin: 0 0 0.75rem 0;
  }

  .page-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.4vw, 2.5rem);
    font-weight: 400;
    line-height: 1.2;
    color: hsl(var(--foreground));
    margin: 0 0 0.85rem 0;
  }

  .page-note {
    font-size: 1rem;
    color: hsl(var(--muted-foreground));
    line-height: 1.55;
    margin: 0 0 1.75rem 0;
  }

  .docs-grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 1fr;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  @media (min-width: 900px) {
    .docs-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .docs-card {
    display: block;
    text-decoration: none;
    color: inherit;
    border: 1px solid hsl(var(--border));
    background: hsl(var(--card));
    overflow: hidden;
    height: 100%;
    transition: border-color 0.25s ease, background 0.25s ease, transform 0.2s ease, box-shadow 0.25s ease;
  }

  .docs-card:hover {
    border-color: hsl(var(--primary) / 0.55);
    background: hsl(var(--card-hover));
    box-shadow: var(--card-glow-hover);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .docs-card:hover .docs-card-title {
    color: hsl(var(--primary));
  }

  .docs-card-inner {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    height: 100%;
  }

  .docs-card-meta {
    font-family: var(--font-display);
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: hsl(var(--muted-foreground));
    margin: 0;
  }

  .meta-category {
    color: hsl(var(--primary));
  }

  .docs-card-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 400;
    color: hsl(var(--foreground));
    margin: 0;
    line-height: 1.25;
    transition: color 0.2s ease;
  }

  .docs-card-description {
    font-size: 0.92rem;
    color: hsl(var(--muted-foreground));
    line-height: 1.55;
    margin: 0;
    flex: 1;
  }

  .docs-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
    padding: 0;
    margin: 0.35rem 0 0 0;
  }

  .tag {
    font-family: var(--font-display);
    font-size: 0.64rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: hsl(var(--muted-foreground));
    background: transparent;
    border: 1px solid hsl(var(--border));
    padding: 0.2rem 0.55rem;
  }
</style>
