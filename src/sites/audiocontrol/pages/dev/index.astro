---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';

if (import.meta.env.PROD) {
  return new Response('Not Found', { status: 404 });
}

interface DevLink {
  href: string;
  title: string;
  blurb: string;
}

interface DevSection {
  heading: string;
  links: DevLink[];
}

const sections: DevSection[] = [
  {
    heading: 'Feature-image pipeline',
    links: [
      {
        href: '/dev/studio/',
        title: 'Feature-image studio',
        blurb: 'Gallery of generated images: review, iterate, approve, apply.',
      },
      {
        href: '/dev/studio/generate',
        title: 'Generate',
        blurb: 'Start a new feature-image workflow from a template or prompt.',
      },
      {
        href: '/dev/studio/templates',
        title: 'Prompt templates',
        blurb: 'Browse and edit the prompt template library (tags, fitness, lineage).',
      },
      {
        href: '/dev/studio/help',
        title: 'Feature-image help',
        blurb: 'Workflow docs for the feature-image pipeline.',
      },
      {
        href: '/dev/feature-image-preview',
        title: 'OG preview',
        blurb: 'Preview the social-share composite for any post.',
      },
      {
        href: '/dev/feature-image-bake',
        title: 'Bake',
        blurb: 'Bake approved images into the final social-ready composites.',
      },
    ],
  },
  {
    heading: 'Editorial pipeline',
    links: [
      {
        href: 'http://localhost:4322/dev/',
        title: 'Editorial studio (editorialcontrol)',
        blurb: 'The unified editorial dashboard lives on the editorialcontrol dev server (default port 4322). Start it with npm run dev:editorialcontrol.',
      },
    ],
  },
];
---

<Layout title="Dev — audiocontrol.org" description="Local development surfaces.">
  <section class="dev-nav">
    <header class="dev-header">
      <p class="panel-label">Dev</p>
      <h1 class="dev-title">Development surfaces.</h1>
      <p class="dev-lede">
        Dev-only tools for this site. All routes 404 in production.
      </p>
      <hr class="rule-ticked" />
    </header>

    {sections.map((section) => (
      <article class="dev-section">
        <h2 class="dev-section-title">{section.heading}</h2>
        <ul class="dev-link-list">
          {section.links.map((link) => (
            <li class="dev-link">
              <a href={link.href} class="dev-link-anchor">
                <span class="dev-link-title">{link.title}</span>
                <span class="dev-link-href">{link.href}</span>
                <span class="dev-link-blurb">{link.blurb}</span>
              </a>
            </li>
          ))}
        </ul>
      </article>
    ))}
  </section>
</Layout>

<style>
  .dev-nav {
    max-width: 52rem;
    margin: 0 auto;
    padding: 2.5rem 0 5rem;
  }

  .dev-header {
    margin-bottom: 2.5rem;
  }

  .panel-label {
    margin: 0 0 0.75rem 0;
  }

  .dev-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.4vw, 2.5rem);
    font-weight: 400;
    line-height: 1.2;
    color: hsl(var(--foreground));
    margin: 0 0 0.85rem 0;
  }

  .dev-lede {
    color: hsl(var(--muted-foreground));
    line-height: 1.55;
    max-width: 42rem;
    margin: 0 0 1.75rem 0;
  }

  .rule-ticked {
    margin-top: 0;
  }

  .dev-section + .dev-section {
    margin-top: 2.5rem;
  }

  .dev-section-title {
    font-family: var(--font-display);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: hsl(var(--muted-foreground));
    margin: 0 0 1rem 0;
  }

  .dev-link-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.6rem;
  }

  .dev-link-anchor {
    display: grid;
    grid-template-columns: 1fr auto;
    row-gap: 0.35rem;
    column-gap: 1rem;
    padding: 0.9rem 1.1rem;
    border: 1px solid hsl(var(--border));
    background: hsl(var(--card));
    color: inherit;
    text-decoration: none;
    transition: border-color 0.2s ease, background 0.2s ease, transform 0.15s ease;
  }

  .dev-link-anchor:hover {
    border-color: hsl(var(--primary) / 0.5);
    background: hsl(var(--card-hover));
    transform: translateY(-1px);
    text-decoration: none;
  }

  .dev-link-title {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    color: hsl(var(--foreground));
  }

  .dev-link-href {
    font-family: var(--font-mono, monospace);
    font-size: 0.78rem;
    color: hsl(var(--muted-foreground));
    align-self: center;
    white-space: nowrap;
  }

  .dev-link-blurb {
    grid-column: 1 / -1;
    font-size: 0.9rem;
    color: hsl(var(--muted-foreground));
    line-height: 1.5;
  }
</style>
