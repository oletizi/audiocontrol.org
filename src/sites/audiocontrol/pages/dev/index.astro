---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';

if (import.meta.env.PROD) {
  return new Response('Not Found', { status: 404 });
}

/**
 * All dev-facing infrastructure — editorial studio, feature-image studio,
 * review surfaces — now lives on editorialcontrol. Running one dev server
 * (editorialcontrol) is enough to reach every surface. Hosting them on
 * a single site also avoids the shared-`.astro/data-store.json` bleed
 * that hit whenever both sites' dev servers ran in parallel.
 *
 * This page is a signpost, not a dashboard.
 */
const editorialcontrolDevUrl = 'http://localhost:4321/dev/';
---

<Layout title="Dev — audiocontrol.org" description="Dev surfaces moved to editorialcontrol.">
  <section class="dev-signpost">
    <p class="kicker">Dev</p>
    <h1 class="dev-title">Moved.</h1>
    <p class="dev-lede">
      All dev-facing surfaces — editorial studio, feature-image studio, review —
      now live on <strong>editorialcontrol</strong>. One dev server runs it all.
    </p>
    <a class="dev-pointer" href={editorialcontrolDevUrl}>
      <span class="dev-pointer-label">Go to dev surfaces →</span>
      <code class="dev-pointer-url">{editorialcontrolDevUrl}</code>
    </a>
    <p class="dev-hint">
      Start the server with <code>npm run dev:editorialcontrol</code> if it isn't running.
    </p>
  </section>
</Layout>

<style>
  .dev-signpost {
    max-width: 44rem;
    margin: 0 auto;
    padding: 4rem 1.5rem;
  }

  .kicker {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: hsl(var(--muted-foreground));
    margin: 0 0 0.6rem 0;
  }

  .dev-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.4vw, 2.4rem);
    font-weight: 400;
    line-height: 1.2;
    margin: 0 0 1rem 0;
  }

  .dev-lede {
    color: hsl(var(--muted-foreground));
    line-height: 1.55;
    margin: 0 0 2rem 0;
  }

  .dev-pointer {
    display: grid;
    gap: 0.35rem;
    padding: 1.1rem 1.25rem;
    border: 1px solid hsl(var(--border));
    background: hsl(var(--card));
    color: inherit;
    text-decoration: none;
    transition: border-color 0.2s ease;
  }
  .dev-pointer:hover { border-color: hsl(var(--primary) / 0.5); }

  .dev-pointer-label {
    font-weight: 600;
    color: hsl(var(--foreground));
  }

  .dev-pointer-url {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: hsl(var(--muted-foreground));
  }

  .dev-hint {
    margin-top: 1.25rem;
    color: hsl(var(--muted-foreground));
    font-size: 0.88rem;
    line-height: 1.5;
  }
</style>
