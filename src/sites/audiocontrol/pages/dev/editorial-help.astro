          </dl>
        </div>

        <div class="eh-ref-block">
          <h4>Review state transitions</h4>
          <table class="eh-transitions">
            <thead><tr><th>from</th><th>to</th></tr></thead>
            <tbody>
              <tr><td>open</td><td class="arrow">→ in-review, cancelled</td></tr>
