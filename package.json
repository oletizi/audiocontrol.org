{
  "name": "audiocontrol.org",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev --config astro.audiocontrol.config.mjs",
    "dev:audiocontrol": "astro dev --config astro.audiocontrol.config.mjs",
    "dev:editorialcontrol": "astro dev --config astro.editorialcontrol.config.mjs",
    "build": "npm run build:audiocontrol && npm run build:editorialcontrol",
    "build:audiocontrol": "npm run generate-og && astro build --config astro.audiocontrol.config.mjs",
    "build:editorialcontrol": "astro build --config astro.editorialcontrol.config.mjs",
    "preview": "astro preview --config astro.audiocontrol.config.mjs",
    "preview:audiocontrol": "astro preview --config astro.audiocontrol.config.mjs",
    "preview:editorialcontrol": "astro preview --config astro.editorialcontrol.config.mjs",
    "astro": "astro",
    "generate-og": "tsx scripts/generate-og-images.ts",
    "generate-feature-image": "tsx scripts/feature-image/cli.ts",
    "test": "vitest run",
    "test:integration": "vitest run test/integration",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@astrojs/netlify": "^6.6.4",
    "@astrojs/sitemap": "^3.7.0",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "astro": "^5.16.15",
    "codemirror": "^6.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "chart.js": "^4.5.1",
    "chartjs-node-canvas": "^5.0.0",
    "cheerio": "^1.2.0",
    "openai": "^6.34.0",
    "satori": "^0.19.1",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "vitest": "^4.1.2",
    "yaml": "^2.8.3"
  }
}
